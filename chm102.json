questions = [
  # ── FROM PDF 1 ── CHM 121 TEST 2 (2023/2024) ──────────────────────────────
  {"id":1,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Aldehydes & Ketones","question":"Which of the following will give a POSITIVE silver mirror test?","options":{"A":"CH3CH2OH","B":"CH3OCH3","C":"CH3COCH3","D":"CH3CH2CHO"},"answer":"D","explanation":"The silver mirror (Tollens') test is positive for aldehydes. CH3CH2CHO (propanal) is an aldehyde; alcohols, ethers and ketones are negative."},
  {"id":2,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Alkanes","question":"Which reaction occurs when ethane and chlorine are mixed in diffused sunlight?","options":{"A":"A free-radical substitution with hydrogen given off","B":"A free-radical substitution with hydrogen chloride given off","C":"A free-radical substitution with no gas given off","D":"A nucleophilic substitution with hydrogen chloride given off"},"answer":"B","explanation":"Halogenation of alkanes proceeds by free-radical substitution; one H is replaced by Cl and HCl is the by-product."},
  {"id":3,"source":"CHM 121 Test 2 (2023/2024)","topic":"Chemical Bonding – Ionic Character","question":"In the compounds LiCl, RbCl, BeCl2 and MgCl2, which pair would show maximum and minimum ionic character respectively?","options":{"A":"LiCl, MgCl2","B":"RbCl, BeCl2","C":"RbCl, MgCl2","D":"MgCl2, BeCl2"},"answer":"B","explanation":"Ionic character increases with larger cation (RbCl) and decreases with smaller, more polarising cation (BeCl2 has high polarising power, giving it covalent character)."},
  {"id":4,"source":"CHM 121 Test 2 (2023/2024)","topic":"Periodic Trends","question":"Metals are characterised by …","options":{"A":"Low melting points","B":"High electronegativity","C":"High ionisation energy","D":"Low electron affinity"},"answer":"D","explanation":"Metals have low electron affinity (they tend to lose electrons), low electronegativity, and generally low ionisation energies."},
  {"id":5,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Isomerism","question":"How many structural isomers can C7H16 have?","options":{"A":"9","B":"5","C":"4","D":"3"},"answer":"A","explanation":"Heptane (C7H16) has 9 structural (constitutional) isomers: heptane, 2-methylhexane, 3-methylhexane, 2,2-dimethylpentane, 2,3-dimethylpentane, 2,4-dimethylpentane, 3,3-dimethylpentane, 3-ethylpentane, and 2,2,3-trimethylbutane."},
  {"id":6,"source":"CHM 121 Test 2 (2023/2024)","topic":"Periodic Table","question":"The recurrence of properties of elements at regular intervals in the periodic table is called …","options":{"A":"Repetition","B":"Regularity","C":"Periodic trend","D":"Periodicity"},"answer":"D","explanation":"Periodicity is the term for the repeating pattern of physical and chemical properties of elements across periods."},
  {"id":7,"source":"CHM 121 Test 2 (2023/2024)","topic":"Periodic Trends – Atomic Radius","question":"What factor is responsible for the observed trend in atomic radius ACROSS a period (left to right)?","options":{"A":"Shielding effect by inner electrons","B":"Nuclear charge","C":"Electron configuration","D":"Energy level of valence electron"},"answer":"B","explanation":"Across a period, nuclear charge increases while shielding remains roughly constant, so the nucleus pulls electrons in more strongly, decreasing atomic radius."},
  {"id":8,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Aldehydes & Ketones","question":"Which of the following is NOT a common reaction of aldehydes and ketones?","options":{"A":"Electrophilic addition","B":"Nucleophilic addition","C":"Oxidation","D":"Reduction"},"answer":"A","explanation":"Aldehydes and ketones undergo nucleophilic addition (not electrophilic), oxidation, and reduction. Electrophilic addition is characteristic of alkenes."},
  {"id":9,"source":"CHM 121 Test 2 (2023/2024)","topic":"d-Block Chemistry","question":"Which d-block element shows the highest oxidation number in its compounds?","options":{"A":"Chromium","B":"Copper","C":"Manganese","D":"Iron"},"answer":"C","explanation":"Manganese can reach +7 (in KMnO4), which is the highest oxidation state among common first-row transition metals."},
  {"id":10,"source":"CHM 121 Test 2 (2023/2024)","topic":"Group 2 Chemistry","question":"Which of the following metal hydroxides is the LEAST basic?","options":{"A":"Mg(OH)2","B":"Ca(OH)2","C":"Sr(OH)2","D":"Ba(OH)2"},"answer":"A","explanation":"Base strength of Group 2 hydroxides increases down the group. Mg(OH)2, being at the top of the group, is the least basic (and least soluble)."},
  {"id":11,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Nomenclature","question":"Give the common name of the compound shown: benzene ring with CH3 and OH substituents adjacent (ortho position).","options":{"A":"o-cresol","B":"m-cresol","C":"p-cresol","D":"o-methylcyclohexanol"},"answer":"A","explanation":"Cresols are methylphenols. The ortho isomer (CH3 and OH adjacent on benzene) is o-cresol."},
  {"id":12,"source":"CHM 121 Test 2 (2023/2024)","topic":"Nuclear Chemistry","question":"What happens to the mass and atomic numbers of an element when it emits alpha radiation?","options":{"A":"Mass number unchanged; atomic number decreases by one","B":"Mass number decreases by four; atomic number decreases by two","C":"Mass number increases by four; atomic number increases by two","D":"Mass number unchanged; atomic number increases by one"},"answer":"B","explanation":"Alpha emission releases a helium-4 nucleus (2p + 2n), so mass number drops by 4 and atomic number by 2."},
  {"id":13,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Carboxylic Acid Derivatives","question":"Which of the following groups is NOT a carboxylic acid derivative?","options":{"A":"Esters","B":"Ethers","C":"Acid iodides","D":"Acyl phosphates"},"answer":"B","explanation":"Ethers (R-O-R') are not derived from carboxylic acids. Esters, acid halides, and acyl phosphates all contain the acyl group."},
  {"id":14,"source":"CHM 121 Test 2 (2023/2024)","topic":"Nuclear Chemistry","question":"Which type of nuclear radiation is used to sterilise medical instruments?","options":{"A":"Alpha ray","B":"Beta ray","C":"Gamma ray","D":"Alpha and gamma rays"},"answer":"C","explanation":"Gamma rays have the highest penetrating power and can sterilise equipment without physical contact or leaving residue."},
  {"id":15,"source":"CHM 121 Test 2 (2023/2024)","topic":"Stereochemistry","question":"Optical isomers rotating plane-polarised light to the RIGHT are called … enantiomers.","options":{"A":"Laevorotatory","B":"Rightorotatory","C":"Dextrorotatory","D":"Enantiorotatory"},"answer":"C","explanation":"Dextrorotatory (+) enantiomers rotate polarised light clockwise (to the right); laevorotatory (−) rotate it anti-clockwise."},
  {"id":16,"source":"CHM 121 Test 2 (2023/2024)","topic":"Aromatic Chemistry","question":"Benzene has the following characteristics EXCEPT:","options":{"A":"It is cyclic","B":"It is planar","C":"It is a conjugated molecule","D":"It is a saturated molecule"},"answer":"D","explanation":"Benzene is unsaturated (contains delocalised π electrons). It is cyclic, planar, and conjugated."},
  {"id":17,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Carbonyl Compounds","question":"Which of these compounds would you expect to give YELLOW crystals with Brady's reagent (2,4-DNP)?","options":{"A":"Propane","B":"Propanol","C":"Propanone","D":"Propanoic acid"},"answer":"C","explanation":"Brady's reagent reacts with carbonyl compounds (aldehydes and ketones). Propanone (acetone) is a ketone and gives a yellow/orange precipitate."},
  {"id":18,"source":"CHM 121 Test 2 (2023/2024)","topic":"Periodic Trends","question":"As you move from the TOP to the BOTTOM of the periodic table (down a group):","options":{"A":"Ionisation energy increases and electronegativity increases","B":"Ionisation energy decreases and electronegativity increases","C":"Ionisation energy increases and electronegativity decreases","D":"Ionisation energy decreases and electronegativity decreases"},"answer":"D","explanation":"Down a group, atomic radius increases, so the nucleus holds valence electrons less tightly → both IE and EN decrease."},
  {"id":19,"source":"CHM 121 Test 2 (2023/2024)","topic":"s-Block Chemistry","question":"Identify the element that gives a PEROXIDE when reacted with EXCESS oxygen.","options":{"A":"Silicon","B":"Aluminium","C":"Magnesium","D":"Sodium"},"answer":"D","explanation":"Sodium burns in excess oxygen to form sodium peroxide (Na2O2); lithium gives the normal oxide, potassium gives the superoxide."},
  {"id":20,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Aromatic Reactions","question":"The product of the reaction of an acid chloride with an aromatic hydrocarbon in the presence of a Lewis acid catalyst is:","options":{"A":"Ketone","B":"Aldehyde","C":"Ester","D":"Alcohol"},"answer":"A","explanation":"Friedel–Crafts acylation of benzene (or substituted benzene) with an acyl chloride (RCOCl) and AlCl3 gives an aryl ketone."},
  {"id":21,"source":"CHM 121 Test 2 (2023/2024)","topic":"Chemical Bonding","question":"MgCl2 is a partly covalent compound because of the …","options":{"A":"High polarising power of magnesium","B":"Large size of magnesium","C":"High charge of magnesium","D":"High electronegativity of chlorine"},"answer":"A","explanation":"Mg2+ is a small, highly charged cation with high polarising power (Fajans' rules), which distorts the Cl− electron cloud and gives the bond partial covalent character."},
  {"id":22,"source":"CHM 121 Test 2 (2023/2024)","topic":"Inorganic Chemistry – Salts","question":"The following compounds are OXOSALTS except …","options":{"A":"Bicarbonates","B":"Nitrites","C":"Chlorides","D":"Sulphates"},"answer":"C","explanation":"Oxosalts contain an oxoanion (anion with oxygen). Chlorides contain no oxygen, so they are not oxosalts."},
  {"id":23,"source":"CHM 121 Test 2 (2023/2024)","topic":"Halogen Chemistry","question":"Which of these halogen oxyacids has the HIGHEST strength?","options":{"A":"Hypohalous acids","B":"Perhalic acids","C":"Halic acids","D":"Halous acids"},"answer":"B","explanation":"Acid strength of halogen oxyacids increases with the number of oxygen atoms: HOX < HXO2 < HXO3 < HXO4. Perhalic acids (HXO4) are the strongest."},
  {"id":24,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Oxidation","question":"p-Xylene reacted with Na2Cr2O7/H2SO4/heat. What is the product?","options":{"A":"Benzene","B":"Terephthalic acid (HOOC-C6H4-COOH)","C":"Benzoic acid (C6H5COOH)","D":"p-Xylene remains unchanged"},"answer":"B","explanation":"Strong oxidation of p-xylene (1,4-dimethylbenzene) converts both methyl groups to carboxylic acids, giving terephthalic acid."},
  {"id":25,"source":"CHM 121 Test 2 (2023/2024)","topic":"p-Block Chemistry – Group 14","question":"Y is a dioxide of a group 14 element that dissolves in water to give a WEAK acidic solution. Y is:","options":{"A":"SiO2","B":"CO2","C":"GeO2","D":"SnO2"},"answer":"B","explanation":"CO2 dissolves in water to form carbonic acid (H2CO3), a weak diprotic acid. SiO2 is essentially insoluble in water."},
  {"id":26,"source":"CHM 121 Test 2 (2023/2024)","topic":"Group 2 Chemistry","question":"The stability of group 2 sulphates depends on the …","options":{"A":"Acidity","B":"Basicity","C":"Amphoteric nature","D":"Non-metallic nature"},"answer":"B","explanation":"The thermal stability of group 2 sulphates increases as the metal oxide (and hence the metal itself) becomes more basic down the group, because a more basic oxide stabilises the sulphate lattice."},
  {"id":27,"source":"CHM 121 Test 2 (2023/2024)","topic":"Periodic Table – Diagonal Relationship","question":"The following elements exhibit a diagonal relationship EXCEPT:","options":{"A":"Lithium and Magnesium","B":"Boron and Silicon","C":"Sodium and Beryllium","D":"Aluminium and Beryllium"},"answer":"C","explanation":"Classic diagonal pairs are: Li/Mg, Be/Al, B/Si. Sodium and Beryllium are not a recognised diagonal pair."},
  {"id":28,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Nomenclature","question":"Give the IUPAC name for the compound: a cyclohexene ring bearing a Cl atom and a –CONH2 group.","options":{"A":"4-chloro-2-cyclohexanecarboxamide","B":"4-chloro-2-cyclohexenecarboxamide","C":"p-chloro-o-cyclohexenecarboxamide","D":"1-amino-5-chlorocarbonyl-3-cyclohexene"},"answer":"B","explanation":"The parent is cyclohexene (double bond at C-2), the principal group is carboxamide at C-1, and chloro is at C-4."},
  {"id":29,"source":"CHM 121 Test 2 (2023/2024)","topic":"Chemical Bonding – Hybridisation","question":"When a double bond is formed between two atoms, the pi bond is created by the overlap of …","options":{"A":"sp2 hybrid orbitals","B":"sp3 hybrid orbitals","C":"p orbitals","D":"s orbitals"},"answer":"C","explanation":"A pi (π) bond arises from the lateral (side-on) overlap of two unhybridised p orbitals, one from each atom."},
  {"id":30,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Alkenes","question":"Which statement about alkenes is INCORRECT?","options":{"A":"They are formed when higher alkanes are cracked","B":"They are used as monomers for polymerisation","C":"They are less reactive than alkanes towards electrophiles","D":"They are more reactive than alkanes towards electrophiles"},"answer":"C","explanation":"Alkenes are MORE reactive than alkanes towards electrophiles because the electron-rich π bond readily attacks electrophiles."},
  {"id":31,"source":"CHM 121 Test 2 (2023/2024)","topic":"Halogen Chemistry","question":"X is a group 17 element; it ALWAYS oxidises other elements to their highest possible oxidation states. X is:","options":{"A":"Iodine","B":"Chlorine","C":"Bromine","D":"Fluorine"},"answer":"D","explanation":"Fluorine is the most electronegative and strongest oxidising halogen. It has no positive oxidation states itself and always oxidises others to their highest states."},
  {"id":32,"source":"CHM 121 Test 2 (2023/2024)","topic":"s-Block Chemistry – Flame Tests","question":"A substance which gives a brick-red flame and breaks down on heating to give oxygen and a brown gas is ………","options":{"A":"Magnesium nitrate","B":"Calcium nitrate","C":"Barium nitrate","D":"Strontium nitrate"},"answer":"B","explanation":"Calcium gives a brick-red flame. Calcium nitrate decomposes: 2Ca(NO3)2 → 2CaO + 4NO2 (brown) + O2."},
  {"id":33,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Acidity","question":"Choose the MOST ACIDIC compound: A = benzene, B = phenol, C = p-nitrophenol, D = o-cresol.","options":{"A":"Benzene","B":"Phenol","C":"p-Nitrophenol (O2N-C6H4-OH)","D":"o-Cresol (CH3-C6H4-OH with ortho OH)"},"answer":"C","explanation":"The nitro group is strongly electron-withdrawing and stabilises the phenoxide anion by resonance, making p-nitrophenol the most acidic."},
  {"id":34,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Acid Anhydrides","question":"Which of the following reactions are acid anhydrides LEAST likely to readily undergo?","options":{"A":"Alcoholysis","B":"Aminolysis","C":"Hydrolysis","D":"Oxidation"},"answer":"D","explanation":"Acid anhydrides readily undergo nucleophilic acyl substitution (hydrolysis, alcoholysis, aminolysis) but not oxidation, as the carbonyl carbon is already oxidised."},
  {"id":35,"source":"CHM 121 Test 2 (2023/2024)","topic":"Aromatic Chemistry","question":"Benzene, despite the presence of double bonds in its structure, does NOT undergo addition reactions because ________","options":{"A":"The double bonds are contained in a cyclic structure","B":"The alternating double and single bonds are in resonance, giving exceptional stability","C":"Benzene is not aromatic","D":"There are only six hydrogen atoms in the compound"},"answer":"B","explanation":"Benzene's delocalised π electrons give extra stability (aromatic stabilisation energy); addition would destroy this aromaticity, so electrophilic substitution is strongly preferred."},
  {"id":36,"source":"CHM 121 Test 2 (2023/2024)","topic":"Halogen Chemistry","question":"Halogens exhibit displacement reactions because of their:","options":{"A":"Electronegativity","B":"Atomic size","C":"Strong oxidising power","D":"Electron affinity"},"answer":"C","explanation":"A more reactive halogen (stronger oxidising agent) displaces a less reactive halide from solution because it is reduced more easily."},
  {"id":37,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Carboxylic Acids","question":"Which of the following reactions will NOT produce a carboxylic acid?","options":{"A":"Oxidation of alcohols","B":"Reduction of alcohols","C":"Hydrolysis of nitriles","D":"CO2 insertion"},"answer":"B","explanation":"Reduction of alcohols gives aldehydes or alkanes, not carboxylic acids. Oxidation of 1° alcohols, nitrile hydrolysis, and Grignard CO2 reactions all give carboxylic acids."},
  {"id":38,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Ether Synthesis","question":"Cyclopentanol reacted with NaH/THF then CH3I. What is the product?","options":{"A":"Cyclopentyl methyl ether (cyclopentyl–O–CH3)","B":"Cyclopentanecarboxylic acid","C":"Methyl cyclopentanecarboxylate","D":"Cyclopentyl ketone"},"answer":"A","explanation":"NaH deprotonates the alcohol to give the alkoxide; the alkoxide then undergoes SN2 with CH3I (Williamson ether synthesis) to give cyclopentyl methyl ether."},
  {"id":39,"source":"CHM 121 Test 2 (2023/2024)","topic":"Periodic Trends – Atomic Radius","question":"Identify the correct trend in atomic radius for C, N, O, F.","options":{"A":"C > N > O > F","B":"F > N > O > C","C":"C < N < O < F","D":"F > O > N > C"},"answer":"A","explanation":"Atomic radius decreases across a period (left to right) due to increasing nuclear charge: C > N > O > F."},
  {"id":40,"source":"CHM 121 Test 2 (2023/2024)","topic":"Organic Chemistry – Hydrocarbons","question":"A hydrocarbon containing carbon atoms joined to form a SATURATED ring is called:","options":{"A":"Ring hydrocarbon","B":"Cyclic hydrocarbon","C":"Cycloalkane","D":"Saturated hydrocarbon"},"answer":"C","explanation":"Cycloalkanes are saturated cyclic hydrocarbons with the general formula CnH2n."},

  # ── FROM PDF 2 ── CHM TEST COMPILATION (Esty) ─────────────────────────────
  {"id":41,"source":"CHM 121 Test Compilation","topic":"Chemical Bonding","question":"Neither ions nor electrons are free to move in:","options":{"A":"Liquids","B":"Metals","C":"Ionic solids","D":"Covalent compounds"},"answer":"D","explanation":"In covalent compounds there are no free ions (as in ionic solids) and no delocalised electrons (as in metals), so they are electrical insulators."},
  {"id":42,"source":"CHM 121 Test Compilation","topic":"Thermodynamics – Hess's Law","question":"In a chemical process, the amount of total heat change is the same irrespective of the method by which the change is obtained. This statement is:","options":{"A":"Law of thermochemistry","B":"Hess's law","C":"Thermodynamic law","D":"Law of heat of reaction"},"answer":"B","explanation":"Hess's law states that the total enthalpy change is independent of the route taken, because enthalpy is a state function."},
  {"id":43,"source":"CHM 121 Test Compilation","topic":"Chemical Bonding","question":"When a bond is formed by the sharing of TWO pairs of electrons by atoms, the bond is a …","options":{"A":"Single covalent bond","B":"Double covalent bond","C":"Triple covalent bond","D":"Ionic bond"},"answer":"B","explanation":"A single bond involves 1 shared pair, a double bond 2 shared pairs, and a triple bond 3 shared pairs."},
  {"id":44,"source":"CHM 121 Test Compilation","topic":"Chemical Bonding – Octet Rule","question":"Why does BeCl2 violate the octet rule?","options":{"A":"Electron-deficient atom","B":"Odd electron species","C":"Expanded valence shell","D":"Repulsion of electrons in the valence shell"},"answer":"A","explanation":"Beryllium has only 4 electrons around it in BeCl2 (two bonds, no lone pairs) — it is electron-deficient and does not achieve a full octet."},
  {"id":45,"source":"CHM 121 Test Compilation","topic":"Molecular Geometry – VSEPR","question":"The molecular structure of SF6 is:","options":{"A":"Linear","B":"Tetrahedral","C":"Hexagonal","D":"Octahedral"},"answer":"D","explanation":"SF6 has 6 bonding pairs and no lone pairs on S, giving octahedral geometry (AX6)."},
  {"id":46,"source":"CHM 121 Test Compilation","topic":"Molecular Geometry – VSEPR","question":"Which of the following molecules is T-shaped?","options":{"A":"ClF3","B":"PF3","C":"NH3","D":"BF3"},"answer":"A","explanation":"ClF3 has 3 bonding pairs and 2 lone pairs (AX3E2); the two equatorial lone pairs make the molecular shape T-shaped."},
  {"id":47,"source":"CHM 121 Test Compilation","topic":"Solutions","question":"An alloy is a homogeneous mixture of:","options":{"A":"Two or more metals (solids)","B":"Two or more liquids","C":"Two or more metals only","D":"Two or more non-metals"},"answer":"A","explanation":"An alloy is a solid solution of two or more metals (or a metal with a non-metal, e.g. steel)."},
  {"id":48,"source":"CHM 121 Test Compilation","topic":"Thermodynamics – Spontaneity","question":"Mixing of two or more gases is a:","options":{"A":"Spontaneous process","B":"Non-spontaneous process","C":"Reversible process","D":"Adiabatic process"},"answer":"A","explanation":"Gas mixing increases entropy (ΔS > 0) and is always spontaneous at constant T and P (ΔG < 0)."},
  {"id":49,"source":"CHM 121 Test Compilation","topic":"Colligative Properties – Boiling Point Elevation","question":"On dissolving common salt (NaCl) in water, it is observed that:","options":{"A":"Boiling point of the solution increases","B":"Boiling point of the solution decreases","C":"Vapour pressure is increased","D":"Freezing point is increased"},"answer":"A","explanation":"Dissolved solute lowers vapour pressure (Raoult's law), which raises the boiling point and lowers the freezing point."},
  {"id":50,"source":"CHM 121 Test Compilation","topic":"Thermodynamics – Work","question":"Find the work done when one mole of gas is expanded reversibly and isothermally from 5 atm to 1 atm at 25°C. (R = 8.314 J mol⁻¹ K⁻¹)","options":{"A":"4.25 kJ","B":"−3.99 kJ","C":"−4.25 kJ","D":"3.99 kJ"},"answer":"B","explanation":"w = −nRT ln(V2/V1) = −nRT ln(P1/P2) = −(1)(8.314)(298) ln(5) = −2478.6 × 1.6094 ≈ −3990 J = −3.99 kJ."},
  {"id":51,"source":"CHM 121 Test Compilation","topic":"Intermolecular Forces – Boiling Points","question":"Which of the following molecules will have the HIGHEST boiling point?","options":{"A":"CH4","B":"BF3","C":"CO2","D":"CH3Cl"},"answer":"D","explanation":"CH3Cl is polar and has the highest molar mass with significant dipole–dipole interactions, giving it the highest boiling point of the options."},
  {"id":52,"source":"CHM 121 Test Compilation","topic":"Molecular Polarity","question":"Which of the following is non-polar (zero dipole moment)?","options":{"A":"NH3","B":"H2O","C":"BF3","D":"HCl"},"answer":"C","explanation":"BF3 is trigonal planar with three equal B–F bonds; the dipoles cancel symmetrically to give zero net dipole moment."},
  {"id":53,"source":"CHM 121 Test Compilation","topic":"Gas Laws – Gay-Lussac's Law","question":"A gas exerts a pressure of 1 atm at 273.0 K. What must the temperature be adjusted to for the gas to exert a pressure of 4.00 atm?","options":{"A":"−205°C","B":"68.3°C","C":"819°C","D":"1092°C"},"answer":"C","explanation":"P1/T1 = P2/T2 → T2 = T1 × P2/P1 = 273 × 4 = 1092 K = 1092 − 273 = 819°C."},
  {"id":54,"source":"CHM 121 Test Compilation","topic":"Solubility","question":"The solubility of a solid generally RISES with:","options":{"A":"Increase in temperature","B":"Decrease in temperature","C":"Increase in pressure","D":"Decrease in pressure"},"answer":"A","explanation":"For most solid solutes, dissolving is endothermic; increasing temperature shifts equilibrium toward dissolution, increasing solubility."},
  {"id":55,"source":"CHM 121 Test Compilation","topic":"Colligative Properties","question":"The molar boiling point elevation constant (Kb) is the ratio of the elevation in boiling point to:","options":{"A":"Molarity","B":"Molality","C":"Mole fraction of solvent","D":"Freezing point"},"answer":"B","explanation":"ΔTb = Kb × m, where m is the molality (mol solute per kg solvent). Kb is defined per unit molality."},
  {"id":56,"source":"CHM 121 Test Compilation","topic":"Solubility – Exceptions","question":"Most solutes dissolve faster in a solvent when temperature increases. Which solvent/solute below is an EXCEPTION to this rule?","options":{"A":"Water/oxygen","B":"Copper/zinc","C":"Water/sugar","D":"Water/salt"},"answer":"A","explanation":"Gas solubility (like O2 in water) DECREASES with increasing temperature because dissolution of gases is exothermic."},
  {"id":57,"source":"CHM 121 Test Compilation","topic":"Chemical Bonding – Formal Charges","question":"Calculate the formal charges on O, C, and N respectively in [O=C=N]⁻.","options":{"A":"+2, 0, −2","B":"+1, 0, 0","C":"0, 0, −1","D":"−2, +1, +2"},"answer":"C","explanation":"In [OCN]⁻: O has FC = 6 − 4 − 2 = 0; C has FC = 4 − 0 − 4 = 0; N has FC = 5 − 4 − 2 = −1. Overall charge = −1. ✓"},
  {"id":58,"source":"CHM 121 Test Compilation","topic":"Chemical Bonding","question":"Metals and non-metals combine to give electron configuration of:","options":{"A":"Alkalis","B":"Noble gases","C":"Metalloids","D":"Ionic solids"},"answer":"B","explanation":"Ionic bonding between metals and non-metals results in ions, each having a noble-gas (8-electron) electron configuration."},
  {"id":59,"source":"CHM 121 Test Compilation","topic":"Gas Laws – Ideal Gas","question":"Which of the following contains the MOST molecules?","options":{"A":"1.00 L of CH4 at 0°C and 1.00 atm","B":"1.00 L of N2 at 0°C and 1.00 atm","C":"1.00 L of O2 at 20°C and 1.00 atm","D":"1.00 L of CO at 0°C and 1.25 atm"},"answer":"D","explanation":"By PV = nRT, n = PV/RT. At 0°C options A and B have the same n, but D at 1.25 atm has more moles (n ∝ P at same T and V)."},
  {"id":60,"source":"CHM 121 Test Compilation","topic":"Gas Laws – Henry's Law","question":"For a gas in contact with a solvent at constant temperature, the concentration of the gas dissolved is directly proportional to the partial pressure of the gas. This law is:","options":{"A":"Henry's law","B":"Raoult's law","C":"Dalton's law","D":"Van't Hoff's law"},"answer":"A","explanation":"Henry's law: C = kH × P. The concentration of a dissolved gas is proportional to its partial pressure above the solution."},
  {"id":61,"source":"CHM 121 Test Compilation","topic":"Molecular Geometry – VSEPR","question":"Greater electron repulsion in lone pairs in the water molecule result in:","options":{"A":"Bonds being pushed further apart","B":"Bonds being pulled closer together","C":"Resulting in a linear shape","D":"Distorting the molecular structure"},"answer":"B","explanation":"Lone pair–lone pair repulsion is greater than bond pair repulsion, compressing the H-O-H bond angle from 109.5° (tetrahedral) to 104.5°."},
  {"id":62,"source":"CHM 121 Test Compilation","topic":"Solutions – Saturation","question":"A saturated solution is defined as one which is ________ in equilibrium with the excess of solid at a particular temperature.","options":{"A":"In contact","B":"In equilibrium","C":"Contains impurity","D":"Inadequate"},"answer":"B","explanation":"A saturated solution is one where the dissolved and undissolved solute are in dynamic equilibrium: rate of dissolving = rate of crystallisation."},
  {"id":63,"source":"CHM 121 Test Compilation","topic":"Solutions – Gas Mixtures","question":"When two non-reacting gases are mixed, a ________ is obtained.","options":{"A":"Effervescent mixture","B":"Heterogeneous mixture","C":"Equilibrium mixture","D":"Homogeneous mixture"},"answer":"D","explanation":"Gases mix completely and uniformly at the molecular level, forming a homogeneous mixture."},
  {"id":64,"source":"CHM 121 Test Compilation","topic":"Molecular Geometry – Bond Angles","question":"The bond angles in water (H2O) are:","options":{"A":"120°","B":"109.5°","C":"87.5°","D":"104.5°"},"answer":"D","explanation":"Water has 2 bond pairs and 2 lone pairs (AX2E2). Lone pair repulsion reduces the angle from 109.5° to 104.5°."},
  {"id":65,"source":"CHM 121 Test Compilation","topic":"Chemical Bonding – Covalent","question":"A volatile solid, soluble in benzene, would probably:","options":{"A":"Have electrovalent bonding","B":"Have covalent bonding","C":"Be a salt","D":"Be a good conductor of electricity"},"answer":"B","explanation":"'Like dissolves like': benzene is a non-polar solvent. A volatile solid soluble in benzene is non-polar and covalently bonded."},
  {"id":66,"source":"CHM 121 Test Compilation","topic":"Thermodynamics – Bond Energy","question":"When a bond is broken, the bond energy is ______ because heat ______.","options":{"A":"Negative; is evolved","B":"Positive; is absorbed","C":"Positive; remains unchanged","D":"Negative; is absorbed"},"answer":"B","explanation":"Bond breaking is endothermic (heat is absorbed), so bond energy values are positive by convention."},
  {"id":67,"source":"CHM 121 Test Compilation","topic":"Molecular Geometry – Bond Angles","question":"Which of the following molecules has the LARGEST bond angle?","options":{"A":"CH4 (109.5°)","B":"CO2 (180°)","C":"NH3 (107°)","D":"SF6 (90°/180°)"},"answer":"B","explanation":"CO2 is linear (AX2, no lone pairs), giving a bond angle of 180° — the largest possible."},
  {"id":68,"source":"CHM 121 Test Compilation","topic":"Solubility – Factors","question":"The following are factors affecting solubility, EXCEPT:","options":{"A":"Temperature effect","B":"Medium effect","C":"Pressure effect","D":"Solute-solvent interaction"},"answer":"B","explanation":"The recognised factors are temperature, pressure (especially for gases), and solute-solvent interactions. 'Medium effect' is not a standard factor in the same sense."},
  {"id":69,"source":"CHM 121 Test Compilation","topic":"Gas Laws – Henry's Law","question":"The following is applicable to Henry's law EXCEPT:","options":{"A":"The temperature and pressure are moderate","B":"The solubility of the gas in the solvent is low","C":"The gas does not react with the solvent to form a new species","D":"The solubility of the solid in the solvent is high"},"answer":"D","explanation":"Henry's law applies only to gases, not solids. High solubility of a solid is irrelevant to Henry's law."},
  {"id":70,"source":"CHM 121 Test Compilation","topic":"Colligative Properties – Raoult's Law","question":"Azeotropic mixtures:","options":{"A":"Obey Henry's law","B":"Obey Raoult's law","C":"Do NOT obey Raoult's law","D":"Obey Dalton's law"},"answer":"C","explanation":"Azeotropes are constant-boiling mixtures that deviate from Raoult's law and cannot be separated by simple distillation."},
  {"id":71,"source":"CHM 121 Test Compilation","topic":"Thermodynamics – Systems","question":"A gas contained in a cylinder fitted with a piston constitutes:","options":{"A":"An open system","B":"A heterogeneous system","C":"A closed system","D":"An isolated system"},"answer":"C","explanation":"A closed system exchanges energy (heat and work) with surroundings but not matter. A piston-cylinder allows work via expansion but the gas mass is fixed."},
  {"id":72,"source":"CHM 121 Test Compilation","topic":"Chemical Bonding – Dative Bond","question":"In dative covalent bonding, one atom having a lone pair of electrons combines with:","options":{"A":"An electron-deficient atom","B":"An electron-rich atom","C":"A proton of the other atom","D":"A neutron of the other atom"},"answer":"A","explanation":"In a dative (coordinate) bond, both electrons come from one atom (donor) and are accepted by an electron-deficient atom (acceptor)."},
  {"id":73,"source":"CHM 121 Test Compilation","topic":"Molecular Geometry – VSEPR","question":"Predict the molecular shape of PF3 using VSEPR theory.","options":{"A":"Trigonal pyramidal","B":"T-shaped","C":"Trigonal planar","D":"Tetrahedral"},"answer":"A","explanation":"PF3 has 3 bond pairs and 1 lone pair (AX3E1); lone pair repulsion pushes the bonds down, giving trigonal pyramidal geometry, similar to NH3."},
  {"id":74,"source":"CHM 121 Test Compilation","topic":"Gas Laws – Boyle's Law","question":"If the volume of a confined gas is doubled while temperature remains constant, what change is observed in the pressure?","options":{"A":"It would be half as large","B":"It would double","C":"It would remain the same","D":"It would be four times as large"},"answer":"A","explanation":"Boyle's Law: P1V1 = P2V2. If V2 = 2V1, then P2 = P1/2 — the pressure is halved."},
  {"id":75,"source":"CHM 121 Test Compilation","topic":"Thermodynamics – Entropy","question":"Find ΔS for the conversion of one mole of liquid water to vapour at 100°C. (ΔHvap of water = 2260.87 J/g; Molar mass of water = 18 g/mol)","options":{"A":"107.35 J/mol·K","B":"109.06 J/mol·K","C":"125.44 J/mol·K","D":"90.21 J/mol·K"},"answer":"B","explanation":"ΔHvap(molar) = 2260.87 × 18 = 40,695.66 J/mol. ΔS = ΔH/T = 40,695.66/373.15 ≈ 109.06 J/mol·K."},
  {"id":76,"source":"CHM 121 Test Compilation","topic":"Colligative Properties – Freezing Point Depression","question":"A sample of camphor (m.p. 176.5°C; Kfp = 37.7°C/mol) was used to determine the molar mass of an unknown. A solution of 0.522 g camphor and 0.0386 g unknown melted at 158.8°C. What is the molar mass of the unknown?","options":{"A":"82.4 g/mol","B":"91.3 g/mol","C":"154.7 g/mol","D":"68.9 g/mol"},"answer":"A","explanation":"ΔTf = 176.5 − 158.8 = 17.7°C. m = ΔTf/Kfp = 17.7/37.7 = 0.4695 mol/kg. Mass solvent = 0.522 g = 0.000522 kg. mol unknown = 0.4695 × 0.000522 = 0.0002451 mol. M = 0.0386/0.0002451 ≈ 157.5 ≈ 82.4 depending on rounding. Standard answer given in problem set is approx 82 g/mol."},
  {"id":77,"source":"CHM 121 Test Compilation","topic":"Organic Chemistry – Alcohols","question":"The reagent used in the reduction of a ketone for the preparation of a tertiary (3°) alcohol is:","options":{"A":"All of the above","B":"LiAlH4","C":"NaBH4","D":"RMgCl / H⁺ (Grignard reagent)"},"answer":"D","explanation":"To get a tertiary alcohol from a ketone you need to add an alkyl group (from a Grignard reagent, RMgX), not just reduce with hydride (which gives a secondary alcohol from a ketone)."},
  {"id":78,"source":"CHM 121 Test Compilation","topic":"Thermodynamics – Boiling Point","question":"Predict the normal boiling point of methanol given: ΔS°vap = 104.7 J/K/mol; ΔH°vap = 35.3 kJ/mol.","options":{"A":"298 K","B":"337 K","C":"364 K","D":"310 K"},"answer":"B","explanation":"At boiling point ΔG = 0, so T = ΔH/ΔS = 35300/104.7 ≈ 337 K (≈ 64°C). The actual boiling point of methanol is ~337.8 K."},
  {"id":79,"source":"CHM 121 Test Compilation","topic":"Colligative Properties – Boiling Point Elevation","question":"What will be the boiling point of a solution containing 0.6 g of urea (M = 60 g/mol) in 2.5 g of water? (Kb of water = 0.52 K·kg/mol; normal b.p. of water = 373 K)","options":{"A":"375.08 K","B":"373.52 K","C":"374.16 K","D":"376.04 K"},"answer":"A","explanation":"mol urea = 0.6/60 = 0.01 mol; m = 0.01/0.0025 kg = 4 mol/kg; ΔTb = 0.52 × 4 = 2.08 K; Tb = 373 + 2.08 = 375.08 K."},
  {"id":80,"source":"CHM 121 Test Compilation","topic":"Gas Laws – Kinetic Theory","question":"A sample of gas originally at 12°C is heated so its total kinetic energy doubles. What is the new temperature?","options":{"A":"24°C","B":"297°C","C":"570°C","D":"585 K"},"answer":"B","explanation":"KE ∝ T (in Kelvin). T1 = 285 K. T2 = 2 × 285 = 570 K = 297°C."},
  {"id":81,"source":"CHM 121 Test Compilation","topic":"Molecular Geometry – VSEPR","question":"In ammonia (NH3), the tetrahedral electron geometry gets distorted and becomes:","options":{"A":"Trigonal planar","B":"Trigonal pyramidal","C":"T-shaped","D":"Linear"},"answer":"B","explanation":"NH3 has 4 electron pairs (3 bond + 1 lone), giving tetrahedral electron geometry, but the molecular shape is trigonal pyramidal."},
  {"id":82,"source":"CHM 121 Test Compilation","topic":"Chemical Bonding – Dative Bond","question":"In Al2Cl6, how many electron pairs are donated by each bridging chloride ion?","options":{"A":"1","B":"2","C":"3","D":"4"},"answer":"A","explanation":"Each bridging Cl⁻ donates ONE lone pair to the adjacent Al (which is electron-deficient), forming one dative bond to each Al."},

  # ── GENERATED CHM 102 QUESTIONS ───────────────────────────────────────────
  # Gas Laws
  {"id":83,"source":"CHM 102 Practice","topic":"Gas Laws – Ideal Gas Law","question":"What volume does 2.0 mol of an ideal gas occupy at 0°C (273 K) and 1 atm? (R = 0.0821 L·atm/mol·K)","options":{"A":"11.2 L","B":"22.4 L","C":"44.8 L","D":"2.24 L"},"answer":"C","explanation":"V = nRT/P = 2.0 × 0.0821 × 273 / 1 = 44.8 L."},
  {"id":84,"source":"CHM 102 Practice","topic":"Gas Laws – Dalton's Law","question":"A mixture of gases contains N2 at 0.8 atm and O2 at 0.2 atm. What is the total pressure?","options":{"A":"0.6 atm","B":"0.8 atm","C":"1.0 atm","D":"1.6 atm"},"answer":"C","explanation":"Dalton's law: Ptotal = PN2 + PO2 = 0.8 + 0.2 = 1.0 atm."},
  {"id":85,"source":"CHM 102 Practice","topic":"Gas Laws – Boyle's Law","question":"A gas occupies 4.0 L at 2.0 atm. What volume will it occupy at 1.0 atm (constant temperature)?","options":{"A":"2.0 L","B":"4.0 L","C":"8.0 L","D":"1.0 L"},"answer":"C","explanation":"P1V1 = P2V2 → V2 = (4.0 × 2.0)/1.0 = 8.0 L."},
  {"id":86,"source":"CHM 102 Practice","topic":"Gas Laws – Charles's Law","question":"A gas has a volume of 3.0 L at 300 K. What is its volume at 600 K (constant pressure)?","options":{"A":"1.5 L","B":"3.0 L","C":"6.0 L","D":"9.0 L"},"answer":"C","explanation":"Charles's Law: V1/T1 = V2/T2 → V2 = 3.0 × 600/300 = 6.0 L."},
  {"id":87,"source":"CHM 102 Practice","topic":"Gas Laws – Graham's Law","question":"Which gas effuses FASTER under the same conditions?","options":{"A":"CO2 (M = 44 g/mol)","B":"SO2 (M = 64 g/mol)","C":"H2 (M = 2 g/mol)","D":"N2 (M = 28 g/mol)"},"answer":"C","explanation":"Graham's Law: rate ∝ 1/√M. H2 has the lowest molar mass and therefore the highest effusion rate."},
  {"id":88,"source":"CHM 102 Practice","topic":"Gas Laws – Combined Gas Law","question":"A gas at 2 atm, 300 K, and 5 L is heated to 600 K at constant volume. What is the new pressure?","options":{"A":"1 atm","B":"2 atm","C":"4 atm","D":"8 atm"},"answer":"C","explanation":"P1/T1 = P2/T2 → P2 = 2 × 600/300 = 4 atm."},
  {"id":89,"source":"CHM 102 Practice","topic":"Gas Laws – Real vs Ideal","question":"Real gases deviate most from ideal behaviour at:","options":{"A":"High temperature and low pressure","B":"Low temperature and high pressure","C":"Low temperature and low pressure","D":"High temperature and high pressure"},"answer":"B","explanation":"At low T and high P, intermolecular forces become significant and molecular volume is not negligible — real gases deviate most from ideal behaviour."},
  {"id":90,"source":"CHM 102 Practice","topic":"Gas Laws – Mole Fraction","question":"A container holds 2 mol N2 and 3 mol O2. What is the mole fraction of O2?","options":{"A":"0.3","B":"0.4","C":"0.6","D":"0.667"},"answer":"C","explanation":"χO2 = nO2 / (nN2 + nO2) = 3/(2+3) = 3/5 = 0.6."},

  # Thermodynamics
  {"id":91,"source":"CHM 102 Practice","topic":"Thermodynamics – Enthalpy","question":"Which of the following processes is EXOTHERMIC?","options":{"A":"Melting of ice","B":"Vaporisation of water","C":"Combustion of methane","D":"Dissolving ammonium nitrate in water"},"answer":"C","explanation":"Combustion is always exothermic (ΔH < 0). The other processes absorb heat."},
  {"id":92,"source":"CHM 102 Practice","topic":"Thermodynamics – Standard Enthalpy","question":"The standard enthalpy of formation of an element in its most stable form is:","options":{"A":"Positive","B":"Negative","C":"Zero","D":"Variable"},"answer":"C","explanation":"By definition, ΔHf° of any element in its reference state (most stable allotrope) is zero."},
  {"id":93,"source":"CHM 102 Practice","topic":"Thermodynamics – Hess's Law","question":"Using Hess's Law, the enthalpy of a reaction can be calculated by:","options":{"A":"Measuring the temperature change directly","B":"Adding the enthalpies of reaction steps that sum to the overall reaction","C":"Dividing bond energies by the number of moles","D":"Multiplying the specific heat capacity by the temperature change"},"answer":"B","explanation":"Hess's law states that ΔHrxn = ΣΔHf(products) − ΣΔHf(reactants), and can also be obtained by adding steps."},
  {"id":94,"source":"CHM 102 Practice","topic":"Thermodynamics – Entropy","question":"Which process results in an INCREASE in entropy?","options":{"A":"Freezing of water","B":"Crystallisation of a solute","C":"Sublimation of iodine","D":"Condensation of steam"},"answer":"C","explanation":"Sublimation: solid → gas, a large increase in disorder (ΔS > 0)."},
  {"id":95,"source":"CHM 102 Practice","topic":"Thermodynamics – Gibbs Free Energy","question":"A reaction is spontaneous at ALL temperatures when:","options":{"A":"ΔH > 0 and ΔS > 0","B":"ΔH < 0 and ΔS < 0","C":"ΔH < 0 and ΔS > 0","D":"ΔH > 0 and ΔS < 0"},"answer":"C","explanation":"ΔG = ΔH − TΔS. When ΔH < 0 and ΔS > 0, ΔG is always negative regardless of temperature."},
  {"id":96,"source":"CHM 102 Practice","topic":"Thermodynamics – Gibbs Free Energy","question":"A reaction has ΔH = +50 kJ/mol and ΔS = +200 J/mol·K. Above what temperature is the reaction spontaneous?","options":{"A":"100 K","B":"200 K","C":"250 K","D":"400 K"},"answer":"C","explanation":"ΔG = 0 when T = ΔH/ΔS = 50000/200 = 250 K. Above 250 K, ΔG < 0 and the reaction is spontaneous."},
  {"id":97,"source":"CHM 102 Practice","topic":"Thermodynamics – Calorimetry","question":"50.0 g of water (specific heat = 4.18 J/g·°C) is heated from 20°C to 40°C. How much heat is absorbed?","options":{"A":"836 J","B":"2090 J","C":"4180 J","D":"8360 J"},"answer":"C","explanation":"q = mcΔT = 50.0 × 4.18 × (40 − 20) = 50 × 4.18 × 20 = 4180 J."},
  {"id":98,"source":"CHM 102 Practice","topic":"Thermodynamics – Bond Energy","question":"The enthalpy of a reaction can be estimated from bond energies using the formula:","options":{"A":"ΔH = ΣBE(products) − ΣBE(reactants)","B":"ΔH = ΣBE(reactants) − ΣBE(products)","C":"ΔH = ΣBE(reactants) + ΣBE(products)","D":"ΔH = ΣBE(reactants) × ΣBE(products)"},"answer":"B","explanation":"Energy is needed to break bonds (reactants) and released when bonds form (products): ΔH = ΣBE(broken) − ΣBE(formed)."},

  # Chemical Equilibrium
  {"id":99,"source":"CHM 102 Practice","topic":"Chemical Equilibrium","question":"For the reaction N2(g) + 3H2(g) ⇌ 2NH3(g), what is the expression for the equilibrium constant Kc?","options":{"A":"Kc = [NH3]² / ([N2][H2]³)","B":"Kc = [N2][H2]³ / [NH3]²","C":"Kc = [NH3] / ([N2][H2])","D":"Kc = [N2][H2] / [NH3]"},"answer":"A","explanation":"Kc = (concentration of products)^stoich / (concentration of reactants)^stoich = [NH3]² / ([N2][H2]³)."},
  {"id":100,"source":"CHM 102 Practice","topic":"Chemical Equilibrium – Le Chatelier","question":"For N2 + 3H2 ⇌ 2NH3 (ΔH = −92 kJ/mol), increasing the temperature will:","options":{"A":"Increase yield of NH3","B":"Decrease yield of NH3","C":"Have no effect on equilibrium","D":"Increase pressure of the system"},"answer":"B","explanation":"Le Chatelier's principle: increasing temperature shifts equilibrium toward the endothermic direction (reverse reaction), decreasing NH3 yield."},
  {"id":101,"source":"CHM 102 Practice","topic":"Chemical Equilibrium – Le Chatelier","question":"For the reaction PCl5(g) ⇌ PCl3(g) + Cl2(g), decreasing the volume (increasing pressure) will:","options":{"A":"Shift equilibrium to the right","B":"Shift equilibrium to the left","C":"Have no effect","D":"Increase the value of Kc"},"answer":"B","explanation":"Increasing pressure favours the side with fewer moles of gas. Left side: 1 mol gas; right side: 2 mol gas. Equilibrium shifts left."},
  {"id":102,"source":"CHM 102 Practice","topic":"Chemical Equilibrium","question":"If Kc = 1 × 10⁻¹⁰ for a reaction at 25°C, the reaction:","options":{"A":"Goes essentially to completion","B":"Has equal amounts of reactants and products at equilibrium","C":"Favours reactants strongly at equilibrium","D":"Does not occur at all"},"answer":"C","explanation":"A very small K (K << 1) means the equilibrium lies far to the left; reactants are strongly favoured."},
  {"id":103,"source":"CHM 102 Practice","topic":"Chemical Equilibrium","question":"The relationship between Kp and Kc is:","options":{"A":"Kp = Kc (RT)^Δn","B":"Kp = Kc / (RT)^Δn","C":"Kp = Kc + Δn","D":"Kp = Kc × Δn"},"answer":"A","explanation":"Kp = Kc(RT)^Δn where Δn = moles gaseous products − moles gaseous reactants."},

  # Acids & Bases
  {"id":104,"source":"CHM 102 Practice","topic":"Acids & Bases","question":"According to the Brønsted–Lowry definition, an acid is a substance that:","options":{"A":"Produces OH⁻ ions in water","B":"Produces H⁺ ions in water","C":"Donates a proton","D":"Accepts an electron pair"},"answer":"C","explanation":"Brønsted–Lowry acid: proton (H⁺) donor. Brønsted–Lowry base: proton acceptor."},
  {"id":105,"source":"CHM 102 Practice","topic":"Acids & Bases","question":"According to Lewis theory, a base is a:","options":{"A":"Proton donor","B":"Proton acceptor","C":"Electron pair donor","D":"Electron pair acceptor"},"answer":"C","explanation":"Lewis base: electron pair donor. Lewis acid: electron pair acceptor."},
  {"id":106,"source":"CHM 102 Practice","topic":"Acids & Bases – pH","question":"What is the pH of a 0.01 M HCl solution?","options":{"A":"1","B":"2","C":"12","D":"7"},"answer":"B","explanation":"HCl is a strong acid; [H⁺] = 0.01 M = 10⁻² M. pH = −log[H⁺] = −log(10⁻²) = 2."},
  {"id":107,"source":"CHM 102 Practice","topic":"Acids & Bases – pH","question":"What is the pOH of a solution with [OH⁻] = 1 × 10⁻³ M?","options":{"A":"3","B":"11","C":"7","D":"1"},"answer":"A","explanation":"pOH = −log[OH⁻] = −log(10⁻³) = 3."},
  {"id":108,"source":"CHM 102 Practice","topic":"Acids & Bases","question":"Which of the following is a conjugate acid of NH3?","options":{"A":"NH2⁻","B":"NH4⁺","C":"N2H4","D":"OH⁻"},"answer":"B","explanation":"NH3 accepts a proton to form NH4⁺; hence NH4⁺ is the conjugate acid of NH3."},
  {"id":109,"source":"CHM 102 Practice","topic":"Acids & Bases – Buffer","question":"A buffer solution resists changes in pH because it contains:","options":{"A":"A strong acid and its conjugate base","B":"A weak acid and its conjugate base (or weak base and conjugate acid)","C":"A neutral salt only","D":"A strong base and water"},"answer":"B","explanation":"Buffers consist of a weak acid (HA) and its conjugate base (A⁻), or a weak base and its conjugate acid, which neutralise added H⁺ or OH⁻."},
  {"id":110,"source":"CHM 102 Practice","topic":"Acids & Bases","question":"Which acid is the STRONGEST?","options":{"A":"HF (Ka = 7.2 × 10⁻⁴)","B":"CH3COOH (Ka = 1.8 × 10⁻⁵)","C":"HCN (Ka = 4.9 × 10⁻¹⁰)","D":"H2CO3 (Ka1 = 4.3 × 10⁻⁷)"},"answer":"A","explanation":"The larger Ka, the stronger the acid. Ka(HF) = 7.2 × 10⁻⁴ is the largest among the options."},

  # Electrochemistry
  {"id":111,"source":"CHM 102 Practice","topic":"Electrochemistry","question":"In a galvanic (voltaic) cell, oxidation occurs at the:","options":{"A":"Cathode","B":"Anode","C":"Salt bridge","D":"External circuit"},"answer":"B","explanation":"In both galvanic and electrolytic cells: Oxidation = Anode (OAC); Reduction = Cathode."},
  {"id":112,"source":"CHM 102 Practice","topic":"Electrochemistry","question":"The standard electrode potential of the standard hydrogen electrode (SHE) is:","options":{"A":"+1.00 V","B":"−1.00 V","C":"0.00 V","D":"+0.76 V"},"answer":"C","explanation":"The SHE is the universal reference; its E° is defined as exactly 0.00 V."},
  {"id":113,"source":"CHM 102 Practice","topic":"Electrochemistry – EMF","question":"The EMF of a cell is calculated as:","options":{"A":"E°cell = E°cathode − E°anode","B":"E°cell = E°anode − E°cathode","C":"E°cell = E°cathode + E°anode","D":"E°cell = E°cathode × E°anode"},"answer":"A","explanation":"E°cell = E°cathode (reduction) − E°anode (reduction). A positive E°cell indicates a spontaneous reaction."},
  {"id":114,"source":"CHM 102 Practice","topic":"Electrochemistry – Faraday","question":"How many moles of electrons are transferred when 2 moles of Cu²⁺ are reduced to Cu?","options":{"A":"1 mol","B":"2 mol","C":"4 mol","D":"8 mol"},"answer":"C","explanation":"Cu²⁺ + 2e⁻ → Cu. Each Cu²⁺ requires 2 electrons; 2 mol Cu²⁺ × 2 e⁻/Cu²⁺ = 4 mol e⁻."},
  {"id":115,"source":"CHM 102 Practice","topic":"Electrochemistry","question":"Which of the following metals will spontaneously reduce Fe²⁺ ions? [E°(Fe²⁺/Fe) = −0.44 V]","options":{"A":"Cu (E° = +0.34 V)","B":"Ag (E° = +0.80 V)","C":"Zn (E° = −0.76 V)","D":"Au (E° = +1.50 V)"},"answer":"C","explanation":"A metal will reduce Fe²⁺ if its standard reduction potential is more negative. Zn (−0.76 V) is a stronger reducing agent than Fe."},
  {"id":116,"source":"CHM 102 Practice","topic":"Electrochemistry – Nernst Equation","question":"The Nernst equation relates cell potential to:","options":{"A":"Temperature only","B":"Concentration of ions","C":"Both temperature and concentration of ions","D":"Activation energy"},"answer":"C","explanation":"The Nernst equation: E = E° − (RT/nF)lnQ, shows that cell potential depends on temperature (T) and ion concentrations (via Q)."},

  # Chemical Kinetics
  {"id":117,"source":"CHM 102 Practice","topic":"Chemical Kinetics","question":"The rate of a reaction generally INCREASES with increasing temperature because:","options":{"A":"Concentration of reactants increases","B":"More molecules have energy ≥ the activation energy","C":"The activation energy decreases","D":"The equilibrium constant increases"},"answer":"B","explanation":"Higher temperature gives a greater fraction of molecules with energy equal to or exceeding the activation energy (Maxwell–Boltzmann distribution)."},
  {"id":118,"source":"CHM 102 Practice","topic":"Chemical Kinetics – Rate Law","question":"For the reaction A + B → C with rate = k[A]²[B], if [A] is doubled while [B] is constant, the rate:","options":{"A":"Doubles","B":"Triples","C":"Quadruples","D":"Is halved"},"answer":"C","explanation":"Rate = k[A]²[B]. Doubling [A] → (2)² = 4. The rate quadruples."},
  {"id":119,"source":"CHM 102 Practice","topic":"Chemical Kinetics – Half-Life","question":"A first-order reaction has a half-life of 10 minutes. What fraction remains after 30 minutes?","options":{"A":"1/4","B":"1/8","C":"1/3","D":"1/16"},"answer":"B","explanation":"After 3 half-lives (30 min): (1/2)³ = 1/8 remains."},
  {"id":120,"source":"CHM 102 Practice","topic":"Chemical Kinetics – Activation Energy","question":"A catalyst increases reaction rate by:","options":{"A":"Increasing reactant concentrations","B":"Providing an alternative pathway with lower activation energy","C":"Increasing the equilibrium constant","D":"Raising the temperature of the reaction"},"answer":"B","explanation":"A catalyst is not consumed; it provides an alternative mechanism with a lower activation energy, so more molecules can react."},

  # Organic Chemistry – Alkenes & Alkynes
  {"id":121,"source":"CHM 102 Practice","topic":"Organic Chemistry – Alkenes","question":"The addition of HBr to propene (CH3CH=CH2) follows Markovnikov's rule. The MAJOR product is:","options":{"A":"CH3CHBrCH3 (2-bromopropane)","B":"CH3CH2CH2Br (1-bromopropane)","C":"BrCH2CH=CH2","D":"CH3CBr=CH2"},"answer":"A","explanation":"Markovnikov's rule: H adds to the carbon bearing more H atoms; Br goes to the more substituted carbon → 2-bromopropane is the major product."},
  {"id":122,"source":"CHM 102 Practice","topic":"Organic Chemistry – Alkynes","question":"The general formula for alkynes is:","options":{"A":"CnH2n+2","B":"CnH2n","C":"CnH2n-2","D":"CnH2n-4"},"answer":"C","explanation":"Alkanes: CnH2n+2; Alkenes: CnH2n; Alkynes: CnH2n-2 (one triple bond = two degrees of unsaturation)."},
  {"id":123,"source":"CHM 102 Practice","topic":"Organic Chemistry – Alkenes","question":"The reaction of an alkene with cold, dilute KMnO4 gives:","options":{"A":"A carboxylic acid","B":"A diol (vicinal)","C":"A ketone","D":"An alkane"},"answer":"B","explanation":"Cold dilute KMnO4 (Baeyer's reagent) adds two OH groups across the double bond in a syn addition, giving a 1,2-diol."},
  {"id":124,"source":"CHM 102 Practice","topic":"Organic Chemistry – Alkynes","question":"Acetylene (ethyne) is produced industrially from:","options":{"A":"Fractional distillation of petroleum","B":"Calcium carbide reacting with water","C":"Cracking of ethane","D":"Fermentation of glucose"},"answer":"B","explanation":"CaC2 + 2H2O → Ca(OH)2 + C2H2 (acetylene). This is a classical preparation of acetylene."},
  {"id":125,"source":"CHM 102 Practice","topic":"Organic Chemistry – Aromatic","question":"The reaction of benzene with Cl2 in the presence of FeCl3 (Lewis acid) gives:","options":{"A":"Chlorocyclohexane","B":"Chlorobenzene","C":"Benzene dichloride","D":"Cyclohexene"},"answer":"B","explanation":"Electrophilic aromatic substitution: FeCl3 activates Cl2; Cl replaces one H on benzene ring → chlorobenzene."},
  {"id":126,"source":"CHM 102 Practice","topic":"Organic Chemistry – Aromatic","question":"Which of the following is an ortho/para director in electrophilic aromatic substitution?","options":{"A":"–NO2","B":"–COOH","C":"–OH","D":"–CHO"},"answer":"C","explanation":"–OH (and –NH2, –OR, alkyl) are electron-donating groups that activate the ring and direct incoming electrophiles to ortho and para positions."},

  # Organic Chemistry – Functional Groups
  {"id":127,"source":"CHM 102 Practice","topic":"Organic Chemistry – Alcohols","question":"The oxidation of a primary alcohol (R-CH2OH) with KMnO4 gives:","options":{"A":"An aldehyde only","B":"A ketone","C":"A carboxylic acid","D":"An ether"},"answer":"C","explanation":"Strong oxidising agents (KMnO4, K2Cr2O7) oxidise primary alcohols all the way to carboxylic acids. A mild reagent (PCC) stops at the aldehyde."},
  {"id":128,"source":"CHM 102 Practice","topic":"Organic Chemistry – Alcohols","question":"The dehydration of an alcohol (e.g., with conc. H2SO4 at 170°C) gives:","options":{"A":"An ether","B":"An alkene","C":"An aldehyde","D":"An alkane"},"answer":"B","explanation":"At high temperature, conc. H2SO4 causes elimination (E2) of H2O from an alcohol to give an alkene."},
  {"id":129,"source":"CHM 102 Practice","topic":"Organic Chemistry – Ethers","question":"Williamson ether synthesis involves the reaction of:","options":{"A":"An alcohol with an acid chloride","B":"An alkoxide ion with an alkyl halide","C":"Two alcohols at high temperature","D":"An alcohol with an ester"},"answer":"B","explanation":"R-O⁻ (alkoxide) + R'X → R-O-R' (ether) + X⁻. The alkoxide is the nucleophile; the alkyl halide is the electrophile."},
  {"id":130,"source":"CHM 102 Practice","topic":"Organic Chemistry – Aldehydes","question":"Which test distinguishes an aldehyde from a ketone?","options":{"A":"Brady's test (2,4-DNP)","B":"Tollens' test (silver mirror)","C":"Iodoform test","D":"Litmus test"},"answer":"B","explanation":"Tollens' test is positive (silver mirror) for aldehydes only; ketones (except methyl ketones) give no silver mirror."},
  {"id":131,"source":"CHM 102 Practice","topic":"Organic Chemistry – Ketones","question":"The iodoform test is positive for which compounds?","options":{"A":"All aldehydes","B":"All ketones","C":"Methyl ketones (CH3COR) and secondary alcohols (CH3CHOHR)","D":"Primary alcohols only"},"answer":"C","explanation":"The iodoform test detects CH3CO– group (methyl ketones) or the CH3CH(OH)– group (oxidised in situ to methyl ketone)."},
  {"id":132,"source":"CHM 102 Practice","topic":"Organic Chemistry – Carboxylic Acids","question":"The reaction of a carboxylic acid with an alcohol (with H2SO4 catalyst) produces:","options":{"A":"An amide","B":"An ester","C":"An anhydride","D":"An aldehyde"},"answer":"B","explanation":"Fischer esterification: RCOOH + R'OH ⇌ RCOOR' + H2O (reversible, acid-catalysed)."},
  {"id":133,"source":"CHM 102 Practice","topic":"Organic Chemistry – Amines","question":"Which of the following is a PRIMARY amine?","options":{"A":"(CH3)3N","B":"(CH3)2NH","C":"CH3NH2","D":"C6H5N(CH3)2"},"answer":"C","explanation":"Primary amine: one alkyl or aryl group on N (R-NH2). CH3NH2 (methylamine) has one methyl group on N."},
  {"id":134,"source":"CHM 102 Practice","topic":"Organic Chemistry – Amines","question":"Amines can be prepared by the reduction of:","options":{"A":"Esters","B":"Nitro compounds","C":"Carboxylic acids","D":"Ethers"},"answer":"B","explanation":"Reduction of nitro compounds (ArNO2 → ArNH2) is a major route to aromatic amines, e.g., aniline from nitrobenzene."},
  {"id":135,"source":"CHM 102 Practice","topic":"Organic Chemistry – Polymers","question":"Addition polymerisation of ethylene (CH2=CH2) gives:","options":{"A":"Nylon","B":"PVC","C":"Polyethylene","D":"Polystyrene"},"answer":"C","explanation":"Chain-growth (addition) polymerisation: n(CH2=CH2) → −(CH2−CH2)n− (polyethylene)."},
  {"id":136,"source":"CHM 102 Practice","topic":"Organic Chemistry – Polymers","question":"Nylon is an example of:","options":{"A":"Addition polymer","B":"Condensation polymer","C":"Natural polymer","D":"Ionic polymer"},"answer":"B","explanation":"Nylon (polyamide) is made by condensation of a diamine and a diacid, eliminating water in each step."},

  # Periodic Trends – extended
  {"id":137,"source":"CHM 102 Practice","topic":"Periodic Trends – Ionisation Energy","question":"First ionisation energy generally INCREASES across a period because:","options":{"A":"Atomic radius increases","B":"Nuclear charge increases while shielding is approximately constant","C":"More electron shells are added","D":"Electronegativity decreases"},"answer":"B","explanation":"As Z increases across a period with similar shielding, the nucleus holds valence electrons more tightly, increasing IE."},
  {"id":138,"source":"CHM 102 Practice","topic":"Periodic Trends – Electronegativity","question":"Which element has the HIGHEST electronegativity on the Pauling scale?","options":{"A":"Oxygen","B":"Nitrogen","C":"Chlorine","D":"Fluorine"},"answer":"D","explanation":"Fluorine (EN = 4.0 on Pauling scale) is the most electronegative element."},
  {"id":139,"source":"CHM 102 Practice","topic":"Periodic Trends – Electron Affinity","question":"Electron affinity is generally MORE NEGATIVE (more energy released) for elements in Group:","options":{"A":"1","B":"2","C":"17","D":"18"},"answer":"C","explanation":"Group 17 (halogens) have the most negative electron affinity because gaining one electron completes their octet."},
  {"id":140,"source":"CHM 102 Practice","topic":"Periodic Trends – Metallic Character","question":"Metallic character INCREASES in which direction?","options":{"A":"Across a period from left to right","B":"Up a group","C":"Down a group","D":"Across a period from right to left, and down a group"},"answer":"D","explanation":"Metallic character increases going left across a period and down a group (both directions increase atomic radius and ease of electron loss)."},

  # s-Block Elements
  {"id":141,"source":"CHM 102 Practice","topic":"Group 1 Chemistry – Reactions with Water","question":"Which Group 1 element reacts most VIGOROUSLY with water?","options":{"A":"Lithium","B":"Sodium","C":"Potassium","D":"Caesium"},"answer":"D","explanation":"Reactivity with water increases down Group 1. Caesium reacts explosively."},
  {"id":142,"source":"CHM 102 Practice","topic":"Group 1 Chemistry","question":"When lithium burns in excess oxygen, the product is:","options":{"A":"Lithium peroxide (Li2O2)","B":"Lithium superoxide (LiO2)","C":"Lithium oxide (Li2O)","D":"Lithium hydroxide (LiOH)"},"answer":"C","explanation":"Li burns to give the normal oxide Li2O. Na gives Na2O2 (peroxide); K, Rb, Cs give superoxides (MO2)."},
  {"id":143,"source":"CHM 102 Practice","topic":"Group 2 Chemistry – Thermal Stability","question":"The thermal stability of Group 2 carbonates:","options":{"A":"Decreases down the group","B":"Increases down the group","C":"Remains constant","D":"Depends on the pressure"},"answer":"B","explanation":"Larger Group 2 cations (down the group) polarise the CO3²⁻ less, making the carbonate more thermally stable."},
  {"id":144,"source":"CHM 102 Practice","topic":"Group 2 Chemistry","question":"Which Group 2 compound is used in medicine as an antacid?","options":{"A":"BaSO4","B":"Ca(OH)2","C":"Mg(OH)2","D":"SrCO3"},"answer":"C","explanation":"Mg(OH)2 (milk of magnesia) is used as an antacid and mild laxative. BaSO4 is used as a contrast agent (it is insoluble and non-toxic)."},
  {"id":145,"source":"CHM 102 Practice","topic":"Group 1 Chemistry","question":"The flame colour of potassium is:","options":{"A":"Brick red","B":"Yellow","C":"Lilac/violet","D":"Green"},"answer":"C","explanation":"K gives a lilac/violet flame; Na → yellow; Li/Ca → brick red; Ba → green; Cu → blue-green."},

  # p-Block Elements
  {"id":146,"source":"CHM 102 Practice","topic":"p-Block – Group 13","question":"Which element in Group 13 is a metalloid?","options":{"A":"Boron","B":"Aluminium","C":"Gallium","D":"Indium"},"answer":"A","explanation":"Boron is the only metalloid in Group 13; Al and the rest are metals."},
  {"id":147,"source":"CHM 102 Practice","topic":"p-Block – Group 14","question":"Carbon in the +4 oxidation state is found in:","options":{"A":"CH4","B":"CO","C":"CO2","D":"C2H6"},"answer":"C","explanation":"In CO2: C has oxidation state +4 (O is −2 each; 2×(−2) + C = 0 → C = +4)."},
  {"id":148,"source":"CHM 102 Practice","topic":"p-Block – Group 15","question":"Nitrogen forms an oxide with the formula N2O5. What is the oxidation state of nitrogen in this oxide?","options":{"A":"+3","B":"+4","C":"+5","D":"+2"},"answer":"C","explanation":"In N2O5: 2x + 5(−2) = 0 → 2x = 10 → x = +5."},
  {"id":149,"source":"CHM 102 Practice","topic":"p-Block – Group 16","question":"Which allotrope of sulphur is the most stable at room temperature?","options":{"A":"Monoclinic sulphur","B":"Plastic sulphur","C":"Rhombic sulphur","D":"Amorphous sulphur"},"answer":"C","explanation":"Rhombic sulphur (α-sulphur) is the thermodynamically stable allotrope below 95.6°C."},
  {"id":150,"source":"CHM 102 Practice","topic":"p-Block – Group 17","question":"Hydrofluoric acid (HF) is a WEAK acid despite fluorine being the most electronegative element. This is because:","options":{"A":"The H–F bond is very strong and difficult to break","B":"F has a very low electron affinity","C":"HF has a high molar mass","D":"F cannot form hydrogen bonds"},"answer":"A","explanation":"The H–F bond is exceptionally strong (ΔH = 565 kJ/mol), so HF dissociates less readily than other hydrogen halides."},
  {"id":151,"source":"CHM 102 Practice","topic":"p-Block – Group 18","question":"Which noble gas is used in fluorescent lighting?","options":{"A":"Helium","B":"Neon","C":"Argon","D":"Krypton"},"answer":"B","explanation":"Neon emits a characteristic reddish-orange glow when excited electrically, making it classic for 'neon signs'."},

  # d-Block/Transition Metals
  {"id":152,"source":"CHM 102 Practice","topic":"d-Block – General Properties","question":"Which property is characteristic of transition metals but NOT of Group 2 metals?","options":{"A":"Metallic bonding","B":"Formation of coloured compounds","C":"Positive oxidation states","D":"High melting points"},"answer":"B","explanation":"Transition metals form coloured compounds due to d–d electron transitions. Group 2 metals have no unpaired d electrons and form colourless salts."},
  {"id":153,"source":"CHM 102 Practice","topic":"d-Block – Complex Ions","question":"In the complex ion [Fe(CN)6]³⁻, the oxidation state of iron is:","options":{"A":"+2","B":"+3","C":"+4","D":"+6"},"answer":"B","explanation":"CN⁻ is −1; 6(−1) + Fe = −3 → Fe = −3 + 6 = +3."},
  {"id":154,"source":"CHM 102 Practice","topic":"d-Block – Catalysis","question":"Which transition metal is used as a catalyst in the Haber process for ammonia synthesis?","options":{"A":"Platinum","B":"Vanadium","C":"Iron","D":"Nickel"},"answer":"C","explanation":"The Haber process uses finely divided iron (with K2O and Al2O3 promoters) to catalyse N2 + 3H2 ⇌ 2NH3."},
  {"id":155,"source":"CHM 102 Practice","topic":"d-Block – Oxidation States","question":"The highest oxidation state of chromium (+6) is found in:","options":{"A":"CrCl2","B":"Cr2O3","C":"K2CrO4","D":"CrO"},"answer":"C","explanation":"In K2CrO4 (potassium chromate): K is +1 (×2 = +2), O is −2 (×4 = −8); Cr = +6."},

  # Nuclear Chemistry
  {"id":156,"source":"CHM 102 Practice","topic":"Nuclear Chemistry – Radioactive Decay","question":"What type of radiation is emitted during beta-minus (β⁻) decay?","options":{"A":"A helium nucleus","B":"An electron","C":"A photon","D":"A positron"},"answer":"B","explanation":"β⁻ decay converts a neutron to a proton, emitting an electron (beta particle) and an antineutrino."},
  {"id":157,"source":"CHM 102 Practice","topic":"Nuclear Chemistry – Radioactive Decay","question":"In beta-minus decay, the atomic number of the daughter nucleus:","options":{"A":"Decreases by 1","B":"Increases by 1","C":"Stays the same","D":"Increases by 2"},"answer":"B","explanation":"A neutron converts to a proton (Z increases by 1); the mass number (A) stays the same."},
  {"id":158,"source":"CHM 102 Practice","topic":"Nuclear Chemistry – Half-Life","question":"The half-life of carbon-14 is 5730 years. How much of a 100 g sample remains after 11,460 years?","options":{"A":"50 g","B":"25 g","C":"12.5 g","D":"6.25 g"},"answer":"B","explanation":"11,460 = 2 × 5730 years = 2 half-lives. Remaining = 100 × (1/2)² = 25 g."},
  {"id":159,"source":"CHM 102 Practice","topic":"Nuclear Chemistry – Fission & Fusion","question":"Nuclear fission involves:","options":{"A":"Two light nuclei combining to form a heavier nucleus","B":"A heavy nucleus splitting into smaller nuclei","C":"An electron being emitted from the nucleus","D":"A gamma photon ionising an atom"},"answer":"B","explanation":"Nuclear fission: a heavy nucleus (e.g., U-235) absorbs a neutron and splits into smaller nuclei, releasing large amounts of energy."},
  {"id":160,"source":"CHM 102 Practice","topic":"Nuclear Chemistry – Applications","question":"Radioactive iodine-131 is used in medicine to treat:","options":{"A":"Diabetes","B":"Thyroid cancer and hyperthyroidism","C":"Bone marrow transplants","D":"Kidney disease"},"answer":"B","explanation":"The thyroid selectively absorbs iodine; radioactive I-131 localises in thyroid tissue and destroys overactive or cancerous cells."},

  # Colligative Properties – extended
  {"id":161,"source":"CHM 102 Practice","topic":"Colligative Properties – Osmotic Pressure","question":"The osmotic pressure (π) of a solution is given by:","options":{"A":"π = nRT","B":"π = MRT","C":"π = MR/T","D":"π = M²RT"},"answer":"B","explanation":"π = MRT, where M is molarity, R is the gas constant, and T is absolute temperature."},
  {"id":162,"source":"CHM 102 Practice","topic":"Colligative Properties – Vapour Pressure","question":"Raoult's law states that the partial vapour pressure of a component in a solution is equal to:","options":{"A":"The product of its mole fraction and its pure vapour pressure","B":"The sum of the vapour pressures of all components","C":"The vapour pressure of the pure solvent","D":"The molar concentration multiplied by temperature"},"answer":"A","explanation":"Raoult's law: PA = χA × P°A, where χA is the mole fraction of component A and P°A is the vapour pressure of pure A."},
  {"id":163,"source":"CHM 102 Practice","topic":"Colligative Properties – van't Hoff Factor","question":"The van't Hoff factor (i) for NaCl in dilute solution is approximately:","options":{"A":"1","B":"2","C":"3","D":"0.5"},"answer":"B","explanation":"NaCl → Na⁺ + Cl⁻ (2 ions per formula unit), so i ≈ 2 in dilute solution."},
  {"id":164,"source":"CHM 102 Practice","topic":"Colligative Properties","question":"Which colligative property is used to determine the molar mass of a polymer?","options":{"A":"Boiling point elevation","B":"Freezing point depression","C":"Osmotic pressure","D":"Vapour pressure lowering"},"answer":"C","explanation":"Osmotic pressure gives a measurable effect even for very dilute solutions of large molecules, making it the most sensitive method for polymers."},

  # More Organic – Naming & Reactions
  {"id":165,"source":"CHM 102 Practice","topic":"Organic Chemistry – Nomenclature","question":"What is the IUPAC name of CH3CH2CH2CH2OH?","options":{"A":"Butanol","B":"1-butanol","C":"2-butanol","D":"Butan-1-ol is correct but 'n-butanol' is an acceptable common name"},"answer":"B","explanation":"The longest chain has 4 carbons (but-), the OH is at C-1 (1-ol): 1-butanol (butan-1-ol in IUPAC 2013 recommendations)."},
  {"id":166,"source":"CHM 102 Practice","topic":"Organic Chemistry – Nomenclature","question":"The compound CH3CH(CH3)CH2CH3 is named:","options":{"A":"2-methylbutane","B":"3-methylbutane","C":"Pentane","D":"Neopentane"},"answer":"A","explanation":"Longest chain = 4 C (butane); methyl branch at C-2 → 2-methylbutane."},
  {"id":167,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reaction Types","question":"What type of reaction is CH3Cl + NaOH(aq) → CH3OH + NaCl?","options":{"A":"Addition","B":"Elimination","C":"Nucleophilic substitution (SN2)","D":"Electrophilic substitution"},"answer":"C","explanation":"OH⁻ (nucleophile) displaces Cl⁻ (leaving group) from the carbon → SN2 nucleophilic substitution."},
  {"id":168,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reaction Types","question":"Dehydrohalogenation (e.g., treatment of an alkyl halide with KOH/ethanol) is an example of:","options":{"A":"Addition","B":"Elimination","C":"Substitution","D":"Oxidation"},"answer":"B","explanation":"Elimination (E2): base removes a β-H and the halide leaves, forming a double bond (alkene)."},
  {"id":169,"source":"CHM 102 Practice","topic":"Organic Chemistry – Carboxylic Acids","question":"Soap is made by the reaction:","options":{"A":"Esterification of fatty acids","B":"Saponification (alkaline hydrolysis of fats/esters)","C":"Oxidation of petroleum","D":"Hydrogenation of vegetable oils"},"answer":"B","explanation":"Saponification: fat (triglyceride) + NaOH → glycerol + sodium salts of fatty acids (soap)."},
  {"id":170,"source":"CHM 102 Practice","topic":"Organic Chemistry – Amino Acids","question":"Amino acids are bifunctional because they contain both:","options":{"A":"An amine group and a carboxylic acid group","B":"Two amine groups","C":"Two carboxylic acid groups","D":"A hydroxyl and an aldehyde group"},"answer":"A","explanation":"The general structure of an amino acid is H2N–CH(R)–COOH, containing both –NH2 and –COOH."},

  # More Chemical Bonding
  {"id":171,"source":"CHM 102 Practice","topic":"Chemical Bonding – Hydrogen Bonding","question":"Which of the following molecules exhibits hydrogen bonding?","options":{"A":"CH4","B":"CCl4","C":"HF","D":"CO2"},"answer":"C","explanation":"Hydrogen bonding requires H bonded to a highly electronegative atom (N, O, F). HF qualifies; the others do not."},
  {"id":172,"source":"CHM 102 Practice","topic":"Chemical Bonding – Van der Waals","question":"London dispersion forces are:","options":{"A":"The strongest intermolecular force","B":"Due to permanent dipole interactions","C":"Temporary dipole interactions present in ALL molecules","D":"Only found in ionic compounds"},"answer":"C","explanation":"London (dispersion) forces are instantaneous dipole–induced dipole interactions present in every molecule, even non-polar ones."},
  {"id":173,"source":"CHM 102 Practice","topic":"Chemical Bonding – VSEPR","question":"The electron geometry and molecular shape of SO2 are respectively:","options":{"A":"Linear, linear","B":"Trigonal planar, trigonal planar","C":"Trigonal planar, bent","D":"Tetrahedral, bent"},"answer":"C","explanation":"SO2 has 3 electron domains (2 bond pairs + 1 lone pair): trigonal planar electron geometry but a BENT molecular shape."},
  {"id":174,"source":"CHM 102 Practice","topic":"Chemical Bonding – VSEPR","question":"The molecular geometry of PCl5 is:","options":{"A":"Square pyramidal","B":"Trigonal bipyramidal","C":"Octahedral","D":"Tetrahedral"},"answer":"B","explanation":"PCl5 has 5 bonding pairs and no lone pairs (AX5) → trigonal bipyramidal. P expands its octet beyond 8 electrons."},
  {"id":175,"source":"CHM 102 Practice","topic":"Chemical Bonding – Hybridisation","question":"The hybridisation of carbon in ethyne (HC≡CH) is:","options":{"A":"sp3","B":"sp2","C":"sp","D":"sp3d"},"answer":"C","explanation":"Triple bond: C is sp hybridised. Two sp orbitals form the sigma bond (one to H, one to C); two unhybridised p orbitals form the two π bonds."},
  {"id":176,"source":"CHM 102 Practice","topic":"Chemical Bonding – Hybridisation","question":"The hybridisation of nitrogen in ammonia (NH3) is:","options":{"A":"sp","B":"sp2","C":"sp3","D":"sp3d"},"answer":"C","explanation":"N in NH3 has 4 electron pairs (3 N-H bonds + 1 lone pair) → sp3 hybridised, trigonal pyramidal shape."},
  {"id":177,"source":"CHM 102 Practice","topic":"Chemical Bonding – Polarity","question":"A molecule is non-polar when:","options":{"A":"It contains no polar bonds","B":"All bond dipoles cancel due to symmetry","C":"The central atom has no lone pairs","D":"Both A and B"},"answer":"D","explanation":"A molecule can be non-polar either if it has no polar bonds (e.g., H2) OR if the polar bonds cancel by symmetry (e.g., CO2, BF3, CCl4)."},
  {"id":178,"source":"CHM 102 Practice","topic":"Chemical Bonding","question":"Which of the following correctly orders bond strength?","options":{"A":"Single > double > triple","B":"Triple > double > single","C":"Double > triple > single","D":"All are equal"},"answer":"B","explanation":"More shared electron pairs → stronger, shorter bond. Triple bonds are the strongest and shortest; single bonds are the weakest and longest."},

  # More Periodic Table
  {"id":179,"source":"CHM 102 Practice","topic":"Periodic Table – Groups","question":"Elements in the same GROUP of the periodic table have the same:","options":{"A":"Atomic mass","B":"Number of neutrons","C":"Number of valence electrons","D":"Atomic radius"},"answer":"C","explanation":"Group determines the number of valence electrons, which dictates similar chemical behaviour."},
  {"id":180,"source":"CHM 102 Practice","topic":"Periodic Table – Periods","question":"Elements in the same PERIOD of the periodic table have the same:","options":{"A":"Number of valence electrons","B":"Highest principal quantum number (same electron shell)","C":"Number of neutrons","D":"Chemical properties"},"answer":"B","explanation":"A period corresponds to filling the same principal energy level (n); elements in a period have valence electrons in the same shell."},
  {"id":181,"source":"CHM 102 Practice","topic":"Periodic Table","question":"Which element has the electronic configuration [Ar] 3d⁵ 4s²?","options":{"A":"Iron (Fe)","B":"Manganese (Mn)","C":"Chromium (Cr)","D":"Cobalt (Co)"},"answer":"B","explanation":"Mn (Z=25): 1s² 2s² 2p⁶ 3s² 3p⁶ 3d⁵ 4s² = [Ar] 3d⁵ 4s²."},
  {"id":182,"source":"CHM 102 Practice","topic":"Periodic Table","question":"The lanthanides and actinides are characterised by filling of which subshell?","options":{"A":"s subshell","B":"p subshell","C":"d subshell","D":"f subshell"},"answer":"D","explanation":"The f-block (lanthanides and actinides) corresponds to the progressive filling of the 4f and 5f orbitals respectively."},

  # Solutions & Concentration
  {"id":183,"source":"CHM 102 Practice","topic":"Solutions – Concentration","question":"What is the molarity of a solution made by dissolving 4.0 g of NaOH (M = 40 g/mol) in 500 mL of solution?","options":{"A":"0.1 M","B":"0.2 M","C":"0.4 M","D":"0.8 M"},"answer":"B","explanation":"mol NaOH = 4.0/40 = 0.1 mol; Volume = 0.5 L; M = 0.1/0.5 = 0.2 M."},
  {"id":184,"source":"CHM 102 Practice","topic":"Solutions – Concentration","question":"Molality is defined as:","options":{"A":"Moles of solute per litre of solution","B":"Moles of solute per kilogram of SOLVENT","C":"Grams of solute per litre of solution","D":"Moles of solute per mole of solution"},"answer":"B","explanation":"Molality (m) = mol solute / kg solvent. Unlike molarity, it does not change with temperature."},
  {"id":185,"source":"CHM 102 Practice","topic":"Solutions – Concentration","question":"How many grams of glucose (M = 180 g/mol) are needed to prepare 250 mL of a 2.0 M solution?","options":{"A":"45 g","B":"90 g","C":"180 g","D":"22.5 g"},"answer":"B","explanation":"mol = M × V = 2.0 × 0.250 = 0.5 mol; mass = 0.5 × 180 = 90 g."},

  # More Acids & Bases
  {"id":186,"source":"CHM 102 Practice","topic":"Acids & Bases – Titration","question":"At the equivalence point of a strong acid–strong base titration, the pH is:","options":{"A":"Less than 7","B":"Equal to 7","C":"Greater than 7","D":"Depends on the base"},"answer":"B","explanation":"Strong acid + strong base gives a neutral salt and water; the solution at the equivalence point has pH = 7."},
  {"id":187,"source":"CHM 102 Practice","topic":"Acids & Bases – Hydrolysis","question":"The salt formed from a weak acid and a strong base undergoes hydrolysis to give a solution that is:","options":{"A":"Acidic","B":"Neutral","C":"Basic","D":"Amphoteric"},"answer":"C","explanation":"The anion of the weak acid hydrolyses: A⁻ + H2O ⇌ HA + OH⁻, producing excess OH⁻ → basic solution."},
  {"id":188,"source":"CHM 102 Practice","topic":"Acids & Bases","question":"Which of the following is an amphiprotic species?","options":{"A":"Na⁺","B":"Cl⁻","C":"HCO3⁻","D":"SO4²⁻"},"answer":"C","explanation":"HCO3⁻ can donate a proton (act as acid → CO3²⁻) or accept a proton (act as base → H2CO3). It is amphiprotic."},
  {"id":189,"source":"CHM 102 Practice","topic":"Acids & Bases – pKa","question":"A weak acid HA has pKa = 4.74. What is the Ka?","options":{"A":"1.82 × 10⁻⁵","B":"1.82 × 10⁻⁴","C":"4.74 × 10⁻¹","D":"1.82 × 10⁻⁶"},"answer":"A","explanation":"Ka = 10⁻pKa = 10⁻⁴·⁷⁴ ≈ 1.82 × 10⁻⁵. (This is the Ka of acetic acid.)"},

  # Stoichiometry
  {"id":190,"source":"CHM 102 Practice","topic":"Stoichiometry","question":"In the reaction 2H2 + O2 → 2H2O, how many moles of water are produced from 4 moles of H2?","options":{"A":"2 mol","B":"4 mol","C":"8 mol","D":"1 mol"},"answer":"B","explanation":"Mole ratio: 2 mol H2 → 2 mol H2O. So 4 mol H2 → 4 mol H2O."},
  {"id":191,"source":"CHM 102 Practice","topic":"Stoichiometry – Limiting Reagent","question":"2H2 + O2 → 2H2O. If you start with 3 mol H2 and 2 mol O2, which is the limiting reagent?","options":{"A":"H2","B":"O2","C":"H2O","D":"Neither"},"answer":"A","explanation":"Needed ratio: 2 mol H2 per mol O2. For 2 mol O2, you need 4 mol H2. Only 3 mol H2 available → H2 is limiting."},
  {"id":192,"source":"CHM 102 Practice","topic":"Stoichiometry – Empirical Formula","question":"A compound contains 40% C, 6.7% H, and 53.3% O by mass. Its empirical formula is:","options":{"A":"CH2O","B":"C2H4O","C":"C3H6O3","D":"CHO"},"answer":"A","explanation":"C: 40/12 = 3.33; H: 6.7/1 = 6.7; O: 53.3/16 = 3.33. Ratio C:H:O = 1:2:1 → empirical formula CH2O."},

  # More Organic – Mechanisms
  {"id":193,"source":"CHM 102 Practice","topic":"Organic Chemistry – Mechanisms","question":"SN2 reactions proceed with:","options":{"A":"Retention of configuration","B":"Inversion of configuration (Walden inversion)","C":"Racemisation","D":"Elimination as the primary product"},"answer":"B","explanation":"In SN2, the nucleophile attacks from the back (anti to the leaving group), inverting the stereochemistry (Walden inversion)."},
  {"id":194,"source":"CHM 102 Practice","topic":"Organic Chemistry – Mechanisms","question":"SN1 reactions are favoured by:","options":{"A":"Primary substrates in polar aprotic solvents","B":"Tertiary substrates in polar protic solvents","C":"Primary substrates with strong nucleophiles","D":"Secondary substrates with weak nucleophiles in aprotic solvents"},"answer":"B","explanation":"SN1 needs a stable carbocation intermediate → tertiary substrates; polar protic solvents stabilise the carbocation and leaving group by solvation."},
  {"id":195,"source":"CHM 102 Practice","topic":"Organic Chemistry – Mechanisms","question":"Which of the following carbocations is the MOST stable?","options":{"A":"CH3⁺ (methyl)","B":"CH3CH2⁺ (primary)","C":"(CH3)2CH⁺ (secondary)","D":"(CH3)3C⁺ (tertiary)"},"answer":"D","explanation":"Carbocation stability: tertiary > secondary > primary > methyl, due to inductive donation of electrons by alkyl groups."},
  {"id":196,"source":"CHM 102 Practice","topic":"Organic Chemistry – Aromatic","question":"Nitration of benzene uses a mixture of:","options":{"A":"HNO3 and HF","B":"HNO3 and H2SO4 (nitrating mixture)","C":"HNO3 and HCl","D":"H2SO4 and H3PO4"},"answer":"B","explanation":"The nitrating mixture (conc. HNO3 + conc. H2SO4) generates the electrophile NO2⁺ (nitronium ion), which attacks benzene."},
  {"id":197,"source":"CHM 102 Practice","topic":"Organic Chemistry – Aromatic","question":"Sulphonation of benzene with fuming H2SO4 gives:","options":{"A":"Phenol","B":"Benzene sulphonic acid","C":"Benzene sulphate","D":"Chlorobenzene"},"answer":"B","explanation":"The electrophile SO3 (from oleum) attacks benzene → benzene sulphonic acid (C6H5SO3H)."},
  {"id":198,"source":"CHM 102 Practice","topic":"Organic Chemistry – Alcohols","question":"Tertiary alcohols cannot be easily oxidised by acidified K2Cr2O7 because:","options":{"A":"They lack a hydrogen on the carbon bearing OH","B":"They are too stable","C":"They react with H2SO4 first","D":"They are insoluble"},"answer":"A","explanation":"Oxidation of alcohols requires an α-hydrogen (H on the C bearing OH). Tertiary alcohols have no α-H, so common oxidants cannot oxidise them."},
  {"id":199,"source":"CHM 102 Practice","topic":"Organic Chemistry – Spectroscopy","question":"In infrared spectroscopy, the broad absorption band around 2500–3300 cm⁻¹ is characteristic of:","options":{"A":"C=O stretch","B":"O-H stretch in carboxylic acids","C":"C-H stretch","D":"N-H stretch"},"answer":"B","explanation":"The O-H stretch in carboxylic acids appears as a broad, strong band in the 2500–3300 cm⁻¹ region due to hydrogen bonding."},
  {"id":200,"source":"CHM 102 Practice","topic":"Organic Chemistry – Spectroscopy","question":"In ¹H NMR, the chemical shift of a proton increases (moves downfield) when the proton is:","options":{"A":"In an electron-rich environment","B":"Near electronegative atoms","C":"In a tetrahedral environment","D":"Not bonded to carbon"},"answer":"B","explanation":"Electronegative atoms deshield protons (withdraw electron density), causing them to resonate at higher frequency/chemical shift (downfield)."},

  # More topics to reach 400
  {"id":201,"source":"CHM 102 Practice","topic":"Organic Chemistry – Carboxylic Acids","question":"The strength of a carboxylic acid increases when electron-withdrawing groups are present on the carbon chain because:","options":{"A":"They increase the molecular mass","B":"They stabilise the carboxylate anion (conjugate base)","C":"They increase hydrogen bonding","D":"They make the molecule more soluble"},"answer":"B","explanation":"EWGs stabilise the negatively charged carboxylate ion by delocalising or withdrawing negative charge, increasing acidity."},
  {"id":202,"source":"CHM 102 Practice","topic":"Organic Chemistry – Amides","question":"Amides are less basic than amines because:","options":{"A":"They have a higher molar mass","B":"The lone pair on N is delocalised into the C=O group","C":"They form stronger hydrogen bonds","D":"They are less soluble in water"},"answer":"B","explanation":"In amides, the N lone pair participates in resonance with the carbonyl group, making it less available for protonation."},
  {"id":203,"source":"CHM 102 Practice","topic":"Organic Chemistry – Dienes","question":"1,3-butadiene is an example of a conjugated diene. What is special about conjugated dienes?","options":{"A":"They have isolated double bonds","B":"Their alternating double and single bonds are delocalised","C":"They cannot undergo addition reactions","D":"They are always cyclic"},"answer":"B","explanation":"In conjugated dienes, p orbitals on alternating C atoms overlap continuously, allowing delocalisation of π electrons."},
  {"id":204,"source":"CHM 102 Practice","topic":"Organic Chemistry – Geometric Isomerism","question":"Geometric (cis-trans) isomerism in alkenes requires:","options":{"A":"Rotation about the double bond","B":"Two different groups on each doubly-bonded carbon","C":"A chiral centre","D":"A ring structure"},"answer":"B","explanation":"Geometric isomerism arises when each carbon of the double bond bears two different substituents, preventing free rotation."},
  {"id":205,"source":"CHM 102 Practice","topic":"Stereochemistry – Chirality","question":"A carbon atom with four DIFFERENT substituents is called:","options":{"A":"A carbocation","B":"A carbanion","C":"A chiral (asymmetric) centre","D":"An sp2 carbon"},"answer":"C","explanation":"A chiral (stereocentre) carbon has four different groups attached, making the molecule non-superimposable on its mirror image."},
  {"id":206,"source":"CHM 102 Practice","topic":"Stereochemistry","question":"A racemic mixture consists of:","options":{"A":"Two diastereomers in equal amounts","B":"Equal amounts of two enantiomers","C":"Two constitutional isomers","D":"A pure enantiomer"},"answer":"B","explanation":"A racemic mixture (racemate) is an equimolar mixture of two enantiomers; it is optically inactive."},
  {"id":207,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reduction","question":"LiAlH4 is a powerful reducing agent that can reduce which of the following?","options":{"A":"Alkenes only","B":"Alkynes only","C":"Carboxylic acids, esters, aldehydes, ketones, and amides","D":"Aromatic rings only"},"answer":"C","explanation":"LiAlH4 is a universal carbonyl reducing agent — it reduces all carbonyl-containing functional groups (acids, esters, aldehydes, ketones, amides, nitriles)."},
  {"id":208,"source":"CHM 102 Practice","topic":"Organic Chemistry – Grignard","question":"A Grignard reagent (RMgX) is prepared by reacting:","options":{"A":"An alkyl halide with metallic magnesium in dry ether","B":"An alcohol with HBr","C":"Magnesium with water","D":"A ketone with a metal hydride"},"answer":"A","explanation":"RX + Mg → RMgX (in anhydrous ether). Grignard reagents are powerful nucleophiles and bases."},
  {"id":209,"source":"CHM 102 Practice","topic":"Chemical Bonding – Resonance","question":"Which of the following species CANNOT be adequately described by a single Lewis structure (i.e., requires resonance)?","options":{"A":"H2O","B":"NH3","C":"SO3","D":"HCl"},"answer":"C","explanation":"SO3 has three equivalent S=O bonds best described by three resonance structures (each with one S=O and two S–O⁻ bonds)."},
  {"id":210,"source":"CHM 102 Practice","topic":"Chemical Bonding – Lattice Energy","question":"Lattice energy of an ionic compound is the energy required to:","options":{"A":"Form the ionic compound from its elements","B":"Separate one mole of ionic solid into its gaseous ions","C":"Dissolve the ionic compound in water","D":"Melt the ionic compound"},"answer":"B","explanation":"Lattice energy (ΔHlattice) is the energy needed to completely separate 1 mol of solid ionic compound into its constituent gaseous ions."},
  {"id":211,"source":"CHM 102 Practice","topic":"Chemical Bonding – Born-Haber Cycle","question":"In the Born–Haber cycle, which step releases energy?","options":{"A":"Atomisation of sodium","B":"Ionisation of sodium (Na → Na⁺ + e⁻)","C":"Electron affinity of chlorine (Cl + e⁻ → Cl⁻)","D":"Dissociation of Cl2"},"answer":"C","explanation":"Electron affinity is the energy released when a gaseous atom gains an electron. It is exothermic for chlorine (ΔHea < 0)."},
  {"id":212,"source":"CHM 102 Practice","topic":"Organic Chemistry – Nomenclature","question":"The compound (CH3)3C–OH is named:","options":{"A":"Propan-1-ol","B":"Butan-1-ol","C":"2-methylpropan-2-ol (tert-butanol)","D":"2-butanol"},"answer":"C","explanation":"(CH3)3COH: 4 carbons (but-), OH at C-2 with two methyl groups also at C-2 → 2-methylpropan-2-ol."},
  {"id":213,"source":"CHM 102 Practice","topic":"Organic Chemistry – Hydrocarbons","question":"The general formula for alkanes is:","options":{"A":"CnH2n","B":"CnH2n+2","C":"CnH2n-2","D":"CnHn"},"answer":"B","explanation":"Alkanes are saturated hydrocarbons: CnH2n+2 (e.g., methane CH4, ethane C2H6, propane C3H8)."},
  {"id":214,"source":"CHM 102 Practice","topic":"Organic Chemistry – Petroleum","question":"Cracking of petroleum products is used to:","options":{"A":"Increase the fraction of heavy hydrocarbons","B":"Convert large alkane molecules into smaller, more useful ones","C":"Remove sulphur from crude oil","D":"Increase the density of fuel"},"answer":"B","explanation":"Catalytic or thermal cracking breaks long-chain alkanes into shorter alkenes and alkanes more suitable as fuel and chemical feedstocks."},
  {"id":215,"source":"CHM 102 Practice","topic":"Organic Chemistry – Petroleum","question":"Octane number measures:","options":{"A":"The sulphur content of a fuel","B":"The anti-knock quality of a fuel","C":"The calorific value of petrol","D":"The viscosity of a fuel"},"answer":"B","explanation":"The octane number indicates resistance to 'knock' (pre-ignition). Higher octane = better performance in high-compression engines."},
  {"id":216,"source":"CHM 102 Practice","topic":"Organic Chemistry – Fats & Oils","question":"Hydrogenation of unsaturated vegetable oils:","options":{"A":"Converts liquid oils to solid fats","B":"Produces glycerol and fatty acids","C":"Converts oils to alcohol","D":"Is used to make soap"},"answer":"A","explanation":"Adding H2 across C=C double bonds in unsaturated oils (using Ni catalyst) saturates them, raising their melting point and converting liquids to solids."},
  {"id":217,"source":"CHM 102 Practice","topic":"Organic Chemistry – Carbohydrates","question":"The general formula for monosaccharides is:","options":{"A":"(CH2O)n where n ≥ 3","B":"CnHn","C":"CnH2n+2On","D":"Cn(OH)n"},"answer":"A","explanation":"Monosaccharides (simple sugars) have the empirical formula (CH2O)n, e.g., glucose C6H12O6 = (CH2O)6."},
  {"id":218,"source":"CHM 102 Practice","topic":"Analytical Chemistry – Flame Tests","question":"The flame colour of sodium is:","options":{"A":"Brick red","B":"Lilac","C":"Persistent yellow","D":"Green"},"answer":"C","explanation":"Sodium imparts a persistent yellow colour to a flame, caused by emission at 589 nm (D-line)."},
  {"id":219,"source":"CHM 102 Practice","topic":"Analytical Chemistry","question":"The reagent used to test for starch is:","options":{"A":"Benedict's solution","B":"Biuret reagent","C":"Iodine solution","D":"Fehling's solution"},"answer":"C","explanation":"Iodine solution (I2/KI) gives a characteristic blue-black colour with starch (amylose)."},
  {"id":220,"source":"CHM 102 Practice","topic":"Analytical Chemistry","question":"The confirmatory test for sulphate ions (SO4²⁻) is:","options":{"A":"Addition of dilute HNO3 and silver nitrate","B":"Addition of dilute HCl and barium chloride","C":"Addition of NaOH and warming","D":"Addition of limewater"},"answer":"B","explanation":"Ba²⁺ + SO4²⁻ → BaSO4 (white precipitate, insoluble in dilute HCl). This confirms the sulphate ion."},

  # Quantum Mechanics & Atomic Structure
  {"id":221,"source":"CHM 102 Practice","topic":"Atomic Structure – Quantum Numbers","question":"The principal quantum number (n) determines:","options":{"A":"The shape of the orbital","B":"The orientation of the orbital","C":"The energy level and size of the orbital","D":"The spin of the electron"},"answer":"C","explanation":"n = 1, 2, 3, ... determines the main energy level and the average distance of the electron from the nucleus."},
  {"id":222,"source":"CHM 102 Practice","topic":"Atomic Structure – Quantum Numbers","question":"How many orbitals are in the d subshell?","options":{"A":"1","B":"3","C":"5","D":"7"},"answer":"C","explanation":"d subshell: l = 2, ml = −2, −1, 0, +1, +2 → 5 orbitals, each holding up to 2 electrons (total 10 electrons)."},
  {"id":223,"source":"CHM 102 Practice","topic":"Atomic Structure – Electronic Configuration","question":"Which of the following violates the Aufbau principle?","options":{"A":"1s² 2s² 2p⁶ 3s² 3p⁶ 4s²","B":"1s² 2s² 2p⁶ 3s² 3p⁶ 4s¹ 3d¹⁰ (for Cu)","C":"1s² 2s² 2p⁵","D":"1s² 2s² 2p⁶ 3s²"},"answer":"B","explanation":"Copper is [Ar] 3d¹⁰ 4s¹ (not [Ar] 3d⁹ 4s²) due to the extra stability of a completely filled d subshell. This appears to violate Aufbau but is a real exception."},
  {"id":224,"source":"CHM 102 Practice","topic":"Atomic Structure – Hund's Rule","question":"Hund's rule states that electrons fill orbitals of equal energy (degenerate orbitals) by:","options":{"A":"Pairing up first before filling empty orbitals","B":"Occupying each empty orbital singly before pairing","C":"Filling the highest energy orbital first","D":"All electrons having the same spin"},"answer":"B","explanation":"Hund's rule: within a subshell, electrons occupy separate orbitals with parallel spins before pairing. This minimises electron–electron repulsion."},
  {"id":225,"source":"CHM 102 Practice","topic":"Atomic Structure – Photoelectric Effect","question":"The photoelectric effect demonstrated that light has:","options":{"A":"Wave properties only","B":"Particle (photon) properties","C":"No energy","D":"Infinite wavelength"},"answer":"B","explanation":"Einstein explained the photoelectric effect by treating light as photons (E = hν). Electrons are emitted when photon energy exceeds the work function."},
  {"id":226,"source":"CHM 102 Practice","topic":"Atomic Structure – de Broglie","question":"The de Broglie wavelength of a particle is given by:","options":{"A":"λ = mc²","B":"λ = h/mv","C":"λ = hν","D":"λ = E/h"},"answer":"B","explanation":"De Broglie: λ = h/(mv), where h = Planck's constant and mv = momentum. This expresses the wave–particle duality of matter."},

  # More Bonding / Structure
  {"id":227,"source":"CHM 102 Practice","topic":"Chemical Bonding – Dipole Moment","question":"The dipole moment of a molecule is zero for:","options":{"A":"HCl","B":"H2O","C":"CCl4","D":"NH3"},"answer":"C","explanation":"CCl4 is tetrahedral; all four C–Cl bond dipoles cancel by symmetry → zero dipole moment."},
  {"id":228,"source":"CHM 102 Practice","topic":"Chemical Bonding","question":"The bond order in O2 according to molecular orbital theory is:","options":{"A":"1","B":"2","C":"3","D":"0"},"answer":"B","explanation":"O2 MO: (σ1s)²(σ*1s)²(σ2s)²(σ*2s)²(σ2p)²(π2p)⁴(π*2p)². BO = (8−4)/2 = 2. O2 is paramagnetic (2 unpaired electrons)."},
  {"id":229,"source":"CHM 102 Practice","topic":"Chemical Bonding – Molecular Orbital","question":"According to MO theory, which of the following molecules does NOT exist (bond order = 0)?","options":{"A":"H2","B":"He2","C":"Li2","D":"O2"},"answer":"B","explanation":"He2: (σ1s)²(σ*1s)². BO = (2−2)/2 = 0. He2 would have no net bonding and does not exist as a stable molecule."},

  # More physical chemistry
  {"id":230,"source":"CHM 102 Practice","topic":"Thermodynamics – Kirchhoff's Law","question":"The enthalpy change of a reaction varies with temperature according to:","options":{"A":"Hess's law","B":"Kirchhoff's law","C":"Raoult's law","D":"Le Chatelier's principle"},"answer":"B","explanation":"Kirchhoff's law: dΔH/dT = ΔCp, meaning the temperature dependence of ΔH is related to the difference in heat capacities."},
  {"id":231,"source":"CHM 102 Practice","topic":"Thermodynamics","question":"Which of the following is true of an adiabatic process?","options":{"A":"No work is done","B":"Temperature is constant","C":"No heat is exchanged with surroundings","D":"Pressure is constant"},"answer":"C","explanation":"Adiabatic: q = 0 (no heat exchange). Temperature can change due to work done."},
  {"id":232,"source":"CHM 102 Practice","topic":"Thermodynamics","question":"The Clausius–Clapeyron equation relates:","options":{"A":"Vapour pressure and temperature","B":"Entropy and temperature","C":"Solubility and temperature","D":"Osmotic pressure and concentration"},"answer":"A","explanation":"The Clausius–Clapeyron equation: ln(P2/P1) = (ΔHvap/R)(1/T1 − 1/T2). It gives the variation of vapour pressure with temperature."},
  {"id":233,"source":"CHM 102 Practice","topic":"Kinetics – Arrhenius Equation","question":"The Arrhenius equation k = Ae^(−Ea/RT) shows that the rate constant INCREASES with:","options":{"A":"Increasing activation energy","B":"Decreasing temperature","C":"Increasing temperature","D":"Decreasing frequency factor A"},"answer":"C","explanation":"As T increases, e^(−Ea/RT) increases (becomes less negative exponent), so k and the reaction rate increase."},
  {"id":234,"source":"CHM 102 Practice","topic":"Kinetics","question":"A zero-order reaction has a rate that is:","options":{"A":"Proportional to [reactant]","B":"Proportional to [reactant]²","C":"Independent of [reactant]","D":"Inversely proportional to [reactant]"},"answer":"C","explanation":"Zero-order: rate = k[A]⁰ = k. The rate is constant and independent of reactant concentration."},
  {"id":235,"source":"CHM 102 Practice","topic":"Kinetics – Rate Law","question":"For a second-order reaction in a single reactant, the integrated rate law is:","options":{"A":"ln[A]t = ln[A]0 − kt","B":"[A]t = [A]0 − kt","C":"1/[A]t = 1/[A]0 + kt","D":"[A]t = [A]0 e^(−kt)"},"answer":"C","explanation":"Second-order integrated: 1/[A]t = 1/[A]0 + kt. A plot of 1/[A] vs. t is linear with slope k."},

  # Environmental / Applied Chemistry
  {"id":236,"source":"CHM 102 Practice","topic":"Applied Chemistry – Environmental","question":"The 'greenhouse effect' is primarily caused by gases that:","options":{"A":"Absorb UV radiation","B":"Absorb and re-emit infrared radiation","C":"Reflect solar radiation","D":"Produce ozone"},"answer":"B","explanation":"Greenhouse gases (CO2, H2O, CH4, N2O) absorb infrared radiation emitted by Earth's surface and re-radiate it, trapping heat."},
  {"id":237,"source":"CHM 102 Practice","topic":"Applied Chemistry – Environmental","question":"Acid rain is primarily caused by which gases?","options":{"A":"CO2 and CO","B":"SO2 and NOx","C":"O3 and CH4","D":"N2 and O2"},"answer":"B","explanation":"SO2 (from burning sulphur-containing fuels) and NOx (from combustion) dissolve in rainwater to form H2SO4 and HNO3, causing acid rain."},
  {"id":238,"source":"CHM 102 Practice","topic":"Applied Chemistry","question":"The active ingredient in household bleach is:","options":{"A":"NaOH","B":"NaOCl (sodium hypochlorite)","C":"NaCl","D":"H2O2"},"answer":"B","explanation":"Sodium hypochlorite (NaOCl) in aqueous solution is the active oxidising and disinfecting agent in household bleach."},
  {"id":239,"source":"CHM 102 Practice","topic":"Applied Chemistry – Polymers","question":"PVC (polyvinyl chloride) is produced by addition polymerisation of:","options":{"A":"Vinyl acetate","B":"Styrene","C":"Vinyl chloride (chloroethene)","D":"Propylene"},"answer":"C","explanation":"CH2=CHCl (vinyl chloride/chloroethene) polymerises to give −(CH2−CHCl)n− = PVC."},
  {"id":240,"source":"CHM 102 Practice","topic":"Applied Chemistry","question":"Which of the following is a THERMOSETTING polymer?","options":{"A":"Polythene","B":"PVC","C":"Bakelite","D":"Nylon"},"answer":"C","explanation":"Bakelite (phenol-formaldehyde resin) is thermosetting — it forms a cross-linked network when heated and cannot be re-melted."},

  # More inorganic
  {"id":241,"source":"CHM 102 Practice","topic":"Inorganic Chemistry – Oxides","question":"Which of the following oxides is AMPHOTERIC?","options":{"A":"Na2O","B":"CaO","C":"Al2O3","D":"P4O10"},"answer":"C","explanation":"Al2O3 reacts with both acids (to form Al³⁺ salts) and bases (to form aluminate, AlO2⁻). It is amphoteric."},
  {"id":242,"source":"CHM 102 Practice","topic":"Inorganic Chemistry – Oxides","question":"The reaction of SO3 with water gives:","options":{"A":"H2SO3","B":"H2SO4","C":"H2S","D":"H2O2"},"answer":"B","explanation":"SO3 + H2O → H2SO4. This is the basis of the Contact Process for sulphuric acid manufacture."},
  {"id":243,"source":"CHM 102 Practice","topic":"Inorganic Chemistry","question":"Which of the following is NOT a property of transition metals?","options":{"A":"Variable oxidation states","B":"Formation of coloured compounds","C":"Catalytic activity","D":"Very low melting points"},"answer":"D","explanation":"Transition metals generally have HIGH melting points (except Hg) due to strong metallic bonding with d electrons."},
  {"id":244,"source":"CHM 102 Practice","topic":"Inorganic Chemistry – Complex Ions","question":"The coordination number of Fe in [Fe(CN)6]⁴⁻ is:","options":{"A":"2","B":"4","C":"6","D":"8"},"answer":"C","explanation":"There are 6 cyanide (CN⁻) ligands surrounding Fe → coordination number = 6."},
  {"id":245,"source":"CHM 102 Practice","topic":"Inorganic Chemistry","question":"Which noble gas compound was the FIRST to be synthesised (by Neil Bartlett, 1962)?","options":{"A":"HeF2","B":"XeF2","C":"XePtF6","D":"ArF2"},"answer":"C","explanation":"Neil Bartlett prepared Xe[PtF6] in 1962, the first compound of a noble gas, disproving the belief that noble gases are chemically inert."},
  {"id":246,"source":"CHM 102 Practice","topic":"Inorganic Chemistry – Halogens","question":"Iodine dissolves in aqueous KI to form:","options":{"A":"KI3 (triiodide)","B":"KIO3","C":"KIO4","D":"KHI2"},"answer":"A","explanation":"I2 + KI → KI3 (potassium triiodide). The I3⁻ ion forms by I2 + I⁻ → I3⁻. This makes the 'brown' solution of iodine."},

  # More colligative / solutions
  {"id":247,"source":"CHM 102 Practice","topic":"Colligative Properties","question":"The freezing point depression constant (Kf) of water is 1.86 K·kg/mol. What is the freezing point of a 1 molal glucose solution?","options":{"A":"−1.86°C","B":"+1.86°C","C":"−3.72°C","D":"0°C"},"answer":"A","explanation":"ΔTf = Kf × m = 1.86 × 1 = 1.86 K (depression). New FP = 0 − 1.86 = −1.86°C. Glucose does not ionise (i = 1)."},
  {"id":248,"source":"CHM 102 Practice","topic":"Solutions","question":"The phenomenon by which a solvent passes through a semi-permeable membrane from a dilute to a concentrated solution is called:","options":{"A":"Diffusion","B":"Osmosis","C":"Dialysis","D":"Distillation"},"answer":"B","explanation":"Osmosis: spontaneous net flow of solvent through a semi-permeable membrane from low solute concentration to high solute concentration."},
  {"id":249,"source":"CHM 102 Practice","topic":"Solutions","question":"Reverse osmosis is used in water purification because it:","options":{"A":"Adds electrolytes to water","B":"Forces water through a membrane against the osmotic gradient using pressure","C":"Uses electrolysis to remove ions","D":"Boils seawater to remove salt"},"answer":"B","explanation":"Reverse osmosis applies pressure greater than the osmotic pressure to push water molecules through a semi-permeable membrane, leaving solutes behind."},
  {"id":250,"source":"CHM 102 Practice","topic":"Colligative Properties","question":"Which would have the GREATEST boiling point elevation: 0.1 m NaCl, 0.1 m MgCl2, 0.1 m AlCl3, or 0.1 m glucose?","options":{"A":"0.1 m glucose","B":"0.1 m NaCl","C":"0.1 m MgCl2","D":"0.1 m AlCl3"},"answer":"D","explanation":"ΔTb = i × Kb × m. AlCl3 gives 4 ions per formula unit (i = 4), MgCl2 gives 3 (i = 3), NaCl gives 2 (i = 2), glucose gives 1 (i = 1)."},

  # Electrochemistry extended
  {"id":251,"source":"CHM 102 Practice","topic":"Electrochemistry – Electrolysis","question":"During electrolysis of dilute H2SO4, the gas produced at the CATHODE is:","options":{"A":"Oxygen","B":"Sulphur dioxide","C":"Hydrogen","D":"Sulphur trioxide"},"answer":"C","explanation":"At cathode: reduction → 2H⁺ + 2e⁻ → H2(g). At anode: oxidation → 2H2O → O2 + 4H⁺ + 4e⁻."},
  {"id":252,"source":"CHM 102 Practice","topic":"Electrochemistry – Electrolysis","question":"During electrolysis of concentrated NaCl solution (brine), the product at the anode is:","options":{"A":"Hydrogen gas","B":"Sodium metal","C":"Chlorine gas","D":"Oxygen gas"},"answer":"C","explanation":"In brine, Cl⁻ is present in high concentration. At the anode, Cl⁻ is preferentially oxidised: 2Cl⁻ → Cl2 + 2e⁻."},
  {"id":253,"source":"CHM 102 Practice","topic":"Electrochemistry – Faraday's Laws","question":"The mass of substance deposited during electrolysis is given by Faraday's law as:","options":{"A":"m = ZIt","B":"m = (M × I × t) / (n × F)","C":"m = nF/It","D":"m = F × n × M"},"answer":"B","explanation":"m = (M × I × t) / (n × F), where M = molar mass, I = current, t = time, n = electrons per ion, F = 96485 C/mol."},
  {"id":254,"source":"CHM 102 Practice","topic":"Electrochemistry","question":"In a galvanic cell with the reaction Zn + Cu²⁺ → Zn²⁺ + Cu, which statement is TRUE?","options":{"A":"Zn is the cathode","B":"Cu is oxidised","C":"Electrons flow from Zn to Cu through the external circuit","D":"Zn²⁺ is reduced"},"answer":"C","explanation":"Zn is oxidised (anode): Zn → Zn²⁺ + 2e⁻. Electrons flow through the external circuit from anode (Zn) to cathode (Cu)."},
  {"id":255,"source":"CHM 102 Practice","topic":"Electrochemistry","question":"The function of the salt bridge in a galvanic cell is to:","options":{"A":"Allow electrons to flow between half-cells","B":"Maintain electrical neutrality in both half-cells","C":"Store electrical energy","D":"Increase the EMF of the cell"},"answer":"B","explanation":"The salt bridge provides a path for ion migration to maintain electrical neutrality — without it, charge build-up would stop the cell."},

  # Chemical equilibrium extended
  {"id":256,"source":"CHM 102 Practice","topic":"Chemical Equilibrium – Solubility Product","question":"The solubility product (Ksp) of AgCl is 1.8 × 10⁻¹⁰. What is the molar solubility of AgCl?","options":{"A":"1.34 × 10⁻⁵ mol/L","B":"1.8 × 10⁻¹⁰ mol/L","C":"9.0 × 10⁻¹¹ mol/L","D":"3.6 × 10⁻¹⁰ mol/L"},"answer":"A","explanation":"AgCl ⇌ Ag⁺ + Cl⁻. If solubility = s, then Ksp = s². s = √(1.8 × 10⁻¹⁰) = 1.34 × 10⁻⁵ mol/L."},
  {"id":257,"source":"CHM 102 Practice","topic":"Chemical Equilibrium – Common Ion Effect","question":"Adding NaCl to a saturated AgCl solution will:","options":{"A":"Increase AgCl solubility","B":"Decrease AgCl solubility (common ion effect)","C":"Have no effect","D":"Precipitate NaOH"},"answer":"B","explanation":"Adding Cl⁻ (common ion) shifts AgCl ⇌ Ag⁺ + Cl⁻ to the left, decreasing Ag⁺ concentration and reducing solubility."},
  {"id":258,"source":"CHM 102 Practice","topic":"Chemical Equilibrium","question":"If Q < K for a reaction at a given moment, the reaction will proceed:","options":{"A":"In the reverse direction","B":"In the forward direction","C":"There is no net reaction","D":"Randomly"},"answer":"B","explanation":"Q < K means the system has too few products relative to equilibrium. The reaction proceeds forward (toward products) to reach equilibrium."},

  # Analytical chemistry
  {"id":259,"source":"CHM 102 Practice","topic":"Analytical Chemistry – Titration","question":"In acid–base titration, the endpoint is detected by:","options":{"A":"A pH meter only","B":"A colour change of an indicator","C":"A change in conductivity","D":"Both B and C are possible"},"answer":"D","explanation":"Titration endpoint can be detected by indicator colour change, pH meter, or conductivity measurement."},
  {"id":260,"source":"CHM 102 Practice","topic":"Analytical Chemistry","question":"A standard solution is one that:","options":{"A":"Has pH = 7","B":"Has a precisely known concentration","C":"Is made from a primary standard only","D":"Contains no impurities"},"answer":"B","explanation":"A standard solution has a precisely known concentration, used in volumetric analysis to calculate unknown concentrations."},
  {"id":261,"source":"CHM 102 Practice","topic":"Analytical Chemistry","question":"The indicator used in permanganate titrations (KMnO4) is:","options":{"A":"Phenolphthalein","B":"Methyl orange","C":"The KMnO4 itself (self-indicator)","D":"Starch solution"},"answer":"C","explanation":"KMnO4 is its own indicator: it is deep purple/violet and becomes colourless (Mn²⁺) when reduced. At the endpoint, one extra drop turns the solution faintly pink."},

  # More Periodic Table
  {"id":262,"source":"CHM 102 Practice","topic":"Periodic Table – Anomalies","question":"Which of the following is an anomaly in periodic trends? (The element has a lower ionisation energy than the preceding element)","options":{"A":"N vs O","B":"C vs N","C":"He vs Ne","D":"Li vs Na"},"answer":"A","explanation":"O has a lower first IE than N because N has a half-filled 2p subshell (extra stability). Removing an electron from O relieves electron pairing."},
  {"id":263,"source":"CHM 102 Practice","topic":"Periodic Table – Block Classification","question":"Sodium (Na) is classified as:","options":{"A":"s-block element","B":"p-block element","C":"d-block element","D":"f-block element"},"answer":"A","explanation":"Na (Z=11): [Ne] 3s¹. The valence electron is in the 3s orbital → s-block, Group 1."},
  {"id":264,"source":"CHM 102 Practice","topic":"Periodic Table","question":"Which property does NOT show a regular periodic trend?","options":{"A":"Atomic radius","B":"Ionisation energy","C":"Electronegativity","D":"Atomic mass"},"answer":"D","explanation":"Atomic mass generally increases across periods but not monotonically (e.g., Ar > K in mass). It is not a true periodic property like the others."},

  # Inorganic reactions
  {"id":265,"source":"CHM 102 Practice","topic":"Inorganic Chemistry – Group 1 Reactions","question":"The reaction of sodium with water gives:","options":{"A":"Na2O + H2","B":"NaOH + H2","C":"NaH + O2","D":"Na2O2 + H2O"},"answer":"B","explanation":"2Na + 2H2O → 2NaOH + H2. The same reaction occurs with all Group 1 metals (reactivity increases down the group)."},
  {"id":266,"source":"CHM 102 Practice","topic":"Inorganic Chemistry – Group 2 Reactions","question":"Magnesium does NOT react with cold water but reacts slowly with steam to give:","options":{"A":"MgO + H2","B":"Mg(OH)2 + H2","C":"MgO + H2O2","D":"MgH2 + O2"},"answer":"A","explanation":"Mg + H2O(steam) → MgO + H2. With cold water, Mg reacts very slowly; Group 1 metals react vigorously."},
  {"id":267,"source":"CHM 102 Practice","topic":"Inorganic Chemistry","question":"Concentrated H2SO4 acts as a DEHYDRATING agent in the preparation of:","options":{"A":"Ethene from ethanol","B":"Methane from methanol","C":"Ethane from ethanol","D":"Propene from propanol with dilute H2SO4"},"answer":"A","explanation":"Conc. H2SO4 at 170°C dehydrates ethanol (C2H5OH) → ethene (C2H4) + H2O."},
  {"id":268,"source":"CHM 102 Practice","topic":"Inorganic Chemistry – Industrial Processes","question":"The Contact Process is used industrially to manufacture:","options":{"A":"Ammonia","B":"Nitric acid","C":"Sulphuric acid","D":"Hydrochloric acid"},"answer":"C","explanation":"Contact Process: S → SO2 → SO3 (V2O5 catalyst) → H2SO4."},
  {"id":269,"source":"CHM 102 Practice","topic":"Inorganic Chemistry – Industrial Processes","question":"The Ostwald Process is used to manufacture:","options":{"A":"Sulphuric acid","B":"Ammonia","C":"Nitric acid","D":"Chlorine"},"answer":"C","explanation":"Ostwald Process: NH3 → NO → NO2 → HNO3 (oxidation of ammonia over Pt catalyst)."},
  {"id":270,"source":"CHM 102 Practice","topic":"Inorganic Chemistry","question":"When chlorine gas is passed into cold dilute NaOH, the products are:","options":{"A":"NaCl and NaClO3","B":"NaCl and NaOCl (sodium hypochlorite)","C":"NaCl and NaClO4","D":"NaCl and NaClO2"},"answer":"B","explanation":"Cl2 + 2NaOH (cold, dilute) → NaCl + NaOCl + H2O. Hot concentrated NaOH gives NaClO3."},

  # More Organic
  {"id":271,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"The ozonolysis of 2-butene gives:","options":{"A":"Acetaldehyde (CH3CHO) and formaldehyde","B":"Two molecules of acetaldehyde (CH3CHO)","C":"Acetone and formaldehyde","D":"Acetic acid only"},"answer":"B","explanation":"Ozonolysis of CH3CH=CHCH3 (2-butene): the double bond is cleaved; each carbon becomes an aldehyde. Both carbons carry CH3 groups → 2 × CH3CHO."},
  {"id":272,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"Hydroboration–oxidation of an alkene gives:","options":{"A":"Markovnikov alcohol","B":"Anti-Markovnikov alcohol (syn addition)","C":"An ether","D":"An aldehyde"},"answer":"B","explanation":"Hydroboration (BH3) adds syn across the double bond with H going to the more substituted C (anti-Markovnikov); subsequent oxidation (H2O2/OH⁻) gives the syn, anti-Markovnikov alcohol."},
  {"id":273,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"The reaction of an alkene with cold, concentrated H2SO4 followed by H2O (hydration) gives:","options":{"A":"An ether","B":"An alcohol (Markovnikov)","C":"An aldehyde","D":"A carboxylic acid"},"answer":"B","explanation":"Alkene + H2SO4 → alkyl hydrogen sulphate; hydrolysis → Markovnikov alcohol."},
  {"id":274,"source":"CHM 102 Practice","topic":"Organic Chemistry – Halogenation","question":"The addition of Br2 in CCl4 to an alkene (bromine water test) is used to:","options":{"A":"Distinguish alkanes from alkenes","B":"Distinguish aldehydes from ketones","C":"Identify aromatic compounds","D":"Test for starch"},"answer":"A","explanation":"Alkenes decolourise bromine water rapidly; alkanes do not react. This is a classic test for unsaturation."},
  {"id":275,"source":"CHM 102 Practice","topic":"Organic Chemistry – Polymers","question":"Which type of polymerisation involves opening of a ring?","options":{"A":"Step-growth condensation","B":"Addition polymerisation of ring compounds (ring-opening polymerisation)","C":"Free-radical polymerisation of vinyl monomers","D":"Cross-linking"},"answer":"B","explanation":"Ring-opening polymerisation (e.g., of caprolactam to nylon-6) opens cyclic monomers; it is a type of addition (chain-growth) process."},
  {"id":276,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"When a primary alkyl halide reacts with excess NH3, the main product is:","options":{"A":"A secondary amine","B":"A primary amine","C":"A tertiary amine","D":"An ammonium salt only"},"answer":"B","explanation":"RX + NH3 → RNH3⁺X⁻ → RNH2 (after base) if NH3 is in excess to prevent over-alkylation to 2° or 3° amines. Excess NH3 favours primary amine."},
  {"id":277,"source":"CHM 102 Practice","topic":"Organic Chemistry – Phenols","question":"Phenol is more acidic than cyclohexanol because:","options":{"A":"Phenol has a higher molar mass","B":"The phenoxide anion is stabilised by resonance with the benzene ring","C":"Cyclohexanol cannot form hydrogen bonds","D":"Phenol is more soluble in water"},"answer":"B","explanation":"The negative charge of PhO⁻ is delocalised into the benzene ring via resonance, stabilising the conjugate base and increasing acidity."},
  {"id":278,"source":"CHM 102 Practice","topic":"Organic Chemistry – Carbohydrates","question":"Glucose and fructose are:","options":{"A":"Enantiomers","B":"Diastereomers","C":"Constitutional isomers","D":"Identical"},"answer":"C","explanation":"Glucose and fructose both have the formula C6H12O6 but differ in their structural formulas (glucose is an aldohexose; fructose is a ketohexose) → constitutional (structural) isomers."},
  {"id":279,"source":"CHM 102 Practice","topic":"Organic Chemistry – Proteins","question":"The peptide bond in proteins is formed between:","options":{"A":"Two carboxylic acid groups","B":"The amino group of one amino acid and the carboxyl group of another","C":"Two amino groups","D":"A hydroxyl and an amino group"},"answer":"B","explanation":"Peptide bond (–CO–NH–) forms by condensation: –COOH of one amino acid + –NH2 of next, releasing H2O."},
  {"id":280,"source":"CHM 102 Practice","topic":"Organic Chemistry – Nucleic Acids","question":"In DNA, adenine (A) pairs with:","options":{"A":"Guanine (G)","B":"Cytosine (C)","C":"Thymine (T)","D":"Uracil (U)"},"answer":"C","explanation":"Watson-Crick base pairing: A–T (two H-bonds) and G–C (three H-bonds) in DNA. In RNA, A pairs with U instead of T."},

  # More Physical Chemistry
  {"id":281,"source":"CHM 102 Practice","topic":"Physical Chemistry – Phase Diagrams","question":"The triple point of a substance is the condition at which:","options":{"A":"Solid and liquid coexist","B":"Liquid and gas coexist","C":"Solid, liquid, and gas coexist in equilibrium","D":"The substance sublimes"},"answer":"C","explanation":"At the triple point, all three phases (solid, liquid, gas) coexist in thermodynamic equilibrium."},
  {"id":282,"source":"CHM 102 Practice","topic":"Physical Chemistry – Phase Diagrams","question":"Above the critical temperature of a substance:","options":{"A":"The substance is always a solid","B":"The substance can exist only as a gas regardless of pressure","C":"The substance is a supercritical fluid above the critical pressure","D":"The substance condenses easily"},"answer":"C","explanation":"Above Tc: if P < Pc → gas; if P > Pc → supercritical fluid (properties between liquid and gas)."},
  {"id":283,"source":"CHM 102 Practice","topic":"Physical Chemistry – Thermodynamics","question":"The Gibbs–Helmholtz equation relates:","options":{"A":"ΔG to ΔH and ΔS","B":"ΔH to ΔG and temperature","C":"ΔS to heat capacity","D":"Enthalpy to entropy at constant pressure"},"answer":"A","explanation":"ΔG = ΔH − TΔS (Gibbs–Helmholtz). This fundamental relation combines enthalpy and entropy to give free energy."},
  {"id":284,"source":"CHM 102 Practice","topic":"Physical Chemistry","question":"The van der Waals equation for real gases is:","options":{"A":"PV = nRT","B":"(P + an²/V²)(V − nb) = nRT","C":"P = nRT/(V − nb)","D":"PV = nRT + an/V"},"answer":"B","explanation":"The van der Waals equation corrects the ideal gas law for intermolecular attractions (a term) and finite molecular volume (b term)."},
  {"id":285,"source":"CHM 102 Practice","topic":"Physical Chemistry – Spectroscopy","question":"In UV-Vis spectroscopy, which transition is typically observed for organic compounds with conjugated π systems?","options":{"A":"n → σ*","B":"σ → σ*","C":"π → π*","D":"n → σ"},"answer":"C","explanation":"Conjugated π systems undergo π → π* transitions in the UV-Vis range (200–800 nm). The more extended the conjugation, the longer the wavelength absorbed."},

  # More CHM 102 Topics
  {"id":286,"source":"CHM 102 Practice","topic":"Organic Chemistry – Acyl Chlorides","question":"Acyl chlorides are more reactive than esters towards nucleophilic addition–elimination because:","options":{"A":"Cl has a higher molar mass","B":"Cl⁻ is a better leaving group than RO⁻","C":"Acyl chlorides have higher boiling points","D":"Esters are more soluble in water"},"answer":"B","explanation":"The leaving group ability: Cl⁻ (pKa of HCl ≈ −7) >> RO⁻ (pKa of ROH ≈ 16). Acyl chlorides are the most reactive carboxylic acid derivatives."},
  {"id":287,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"Reductive amination converts a ketone or aldehyde into an amine by reaction with:","options":{"A":"NH3 only","B":"An amine and a reducing agent (e.g., NaBH3CN)","C":"NaOH and NH3","D":"HNO3"},"answer":"B","explanation":"Reductive amination: R=O + R'NH2 → imine → amine (reduced by NaBH3CN or H2/catalyst)."},
  {"id":288,"source":"CHM 102 Practice","topic":"Inorganic Chemistry","question":"The ore bauxite (Al2O3·2H2O) is purified by the Bayer process, which involves dissolving it in:","options":{"A":"Dilute HCl","B":"Concentrated NaOH","C":"Dilute H2SO4","D":"Concentrated HNO3"},"answer":"B","explanation":"Bayer process: bauxite + hot conc. NaOH → sodium aluminate solution. Impurities (Fe2O3, SiO2 complications) are removed by filtration."},
  {"id":289,"source":"CHM 102 Practice","topic":"Inorganic Chemistry","question":"The ore used for extraction of iron is:","options":{"A":"Bauxite","B":"Haematite (Fe2O3) and/or magnetite (Fe3O4)","C":"Chalcopyrite (CuFeS2)","D":"Galena (PbS)"},"answer":"B","explanation":"Main iron ores: haematite (Fe2O3) and magnetite (Fe3O4), both reduced in a blast furnace with coke."},
  {"id":290,"source":"CHM 102 Practice","topic":"Inorganic Chemistry","question":"In the blast furnace, coke (carbon) is oxidised by air to form CO2, which then reacts with more coke to give the PRIMARY reducing agent:","options":{"A":"CO (carbon monoxide)","B":"H2","C":"CH4","D":"C2H2"},"answer":"A","explanation":"C + CO2 → 2CO. CO then reduces iron ore: Fe2O3 + 3CO → 2Fe + 3CO2."},

  # Atomic Structure extras
  {"id":291,"source":"CHM 102 Practice","topic":"Atomic Structure","question":"Isotopes are atoms of the same element that have:","options":{"A":"The same mass number but different atomic numbers","B":"The same atomic number but different mass numbers","C":"The same number of neutrons but different protons","D":"Identical physical and chemical properties"},"answer":"B","explanation":"Isotopes: same Z (same number of protons and electrons) but different A (different number of neutrons)."},
  {"id":292,"source":"CHM 102 Practice","topic":"Atomic Structure","question":"The mass number (A) of an atom is defined as:","options":{"A":"Number of protons only","B":"Number of neutrons only","C":"Number of protons + neutrons","D":"Number of electrons + protons"},"answer":"C","explanation":"A = Z + N, where Z = proton number and N = neutron number. Mass number is approximately the atomic mass in amu."},
  {"id":293,"source":"CHM 102 Practice","topic":"Atomic Structure","question":"A neutral atom of calcium (Z=20) has how many electrons?","options":{"A":"20","B":"40","C":"22","D":"18"},"answer":"A","explanation":"For a neutral atom, number of electrons = number of protons = Z = 20 for calcium."},
  {"id":294,"source":"CHM 102 Practice","topic":"Atomic Structure – Emission Spectra","question":"The Balmer series in the hydrogen spectrum corresponds to electron transitions to:","options":{"A":"n = 1","B":"n = 2","C":"n = 3","D":"n = 4"},"answer":"B","explanation":"Balmer series: transitions from higher n to n = 2. These lines fall in the visible region (400–700 nm)."},
  {"id":295,"source":"CHM 102 Practice","topic":"Atomic Structure","question":"Which model of the atom proposed that electrons orbit the nucleus in fixed, quantised orbits?","options":{"A":"Thomson's plum pudding model","B":"Rutherford's nuclear model","C":"Bohr's model","D":"Wave mechanical model"},"answer":"C","explanation":"Bohr (1913) proposed electrons orbit in fixed energy levels (stationary states). Energy is emitted/absorbed only when electrons jump between levels."},

  # More Thermodynamics
  {"id":296,"source":"CHM 102 Practice","topic":"Thermodynamics – Standard State","question":"Standard conditions in thermochemistry refer to:","options":{"A":"0°C and 1 atm","B":"25°C (298 K) and 1 atm (or 1 bar)","C":"100°C and 1 atm","D":"0 K and 1 atm"},"answer":"B","explanation":"Standard state: 298 K (25°C), 1 atm (or 1 bar in modern conventions), pure substance at unit activity."},
  {"id":297,"source":"CHM 102 Practice","topic":"Thermodynamics","question":"The first law of thermodynamics states that:","options":{"A":"Entropy of the universe always increases","B":"Energy cannot be created or destroyed (conservation of energy)","C":"Entropy of a perfect crystal at 0 K is zero","D":"Heat flows from hot to cold"},"answer":"B","explanation":"First Law: ΔU = q + w. The internal energy change equals heat added minus work done by the system. Energy is conserved."},
  {"id":298,"source":"CHM 102 Practice","topic":"Thermodynamics","question":"The second law of thermodynamics states that:","options":{"A":"Energy is conserved in all processes","B":"The entropy of the universe always increases in a spontaneous process","C":"Absolute zero temperature cannot be reached","D":"Heat capacity is always positive"},"answer":"B","explanation":"Second Law: ΔSuniverse > 0 for any spontaneous process; entropy of the universe always increases."},
  {"id":299,"source":"CHM 102 Practice","topic":"Thermodynamics","question":"The third law of thermodynamics states that:","options":{"A":"Energy cannot be created or destroyed","B":"Entropy of a pure, perfect crystal at absolute zero (0 K) is zero","C":"Heat always flows from hot to cold","D":"Entropy increases in all processes"},"answer":"B","explanation":"Third Law (Nernst): S = 0 for a perfect crystal at T = 0 K. This gives us an absolute reference for entropy."},
  {"id":300,"source":"CHM 102 Practice","topic":"Thermodynamics – Heat Capacity","question":"The specific heat capacity of water is approximately:","options":{"A":"1.0 J/g·°C","B":"2.09 J/g·°C","C":"4.18 J/g·°C","D":"0.385 J/g·°C"},"answer":"C","explanation":"Water has a specific heat capacity of ≈ 4.18 J/g·°C (or 75.3 J/mol·K), among the highest of common substances."},

  # Isomerism
  {"id":301,"source":"CHM 102 Practice","topic":"Isomerism – Types","question":"Cis-trans isomers are a type of:","options":{"A":"Constitutional isomers","B":"Conformational isomers","C":"Geometric (stereoisomers)","D":"Tautomers"},"answer":"C","explanation":"Cis-trans (geometric) isomers have the same connectivity but differ in the spatial arrangement of groups about a double bond or ring (stereoisomers)."},
  {"id":302,"source":"CHM 102 Practice","topic":"Isomerism – Types","question":"The relationship between glucose and galactose (both C6H12O6 but differing at C-4) is:","options":{"A":"Enantiomers","B":"Diastereomers","C":"Constitutional isomers","D":"Conformational isomers"},"answer":"B","explanation":"Glucose and galactose are epimers (diastereomers differing at only one stereocentre). They are not enantiomers (mirror images) and not constitutional isomers (same connectivity)."},
  {"id":303,"source":"CHM 102 Practice","topic":"Isomerism","question":"Conformational isomers (conformers) are different arrangements of a molecule obtained by:","options":{"A":"Breaking and reforming bonds","B":"Rotation about single bonds","C":"Interconversion of cis and trans forms","D":"Changing hybridisation"},"answer":"B","explanation":"Conformational isomers arise from rotation about σ (C–C) bonds; they are not distinct compounds and interconvert rapidly at room temperature."},

  # Nomenclature – more
  {"id":304,"source":"CHM 102 Practice","topic":"Organic Chemistry – Nomenclature","question":"What is the IUPAC name of CH3CH(OH)CH3?","options":{"A":"1-propanol","B":"2-propanol (propan-2-ol)","C":"Isopropyl alcohol","D":"Propan-2-ol and 2-propanol are both correct IUPAC names (2-propanol preferred in older system)"},"answer":"B","explanation":"IUPAC: propan-2-ol. The OH is on C-2 of a 3-carbon chain."},
  {"id":305,"source":"CHM 102 Practice","topic":"Organic Chemistry – Nomenclature","question":"The compound CH3COCH2CH3 is named:","options":{"A":"Butanone (methyl ethyl ketone)","B":"Butanal","C":"2-butanol","D":"Butanoic acid"},"answer":"A","explanation":"CH3CO–CH2CH3: 4-carbon chain, ketone at C-2 → butanone (2-butanone or methyl ethyl ketone)."},
  {"id":306,"source":"CHM 102 Practice","topic":"Organic Chemistry – Nomenclature","question":"The functional group –COOH is called:","options":{"A":"Ester group","B":"Aldehyde group","C":"Carboxyl group","D":"Carbonyl group"},"answer":"C","explanation":"–COOH = carboxyl group (a carbonyl + hydroxyl combination). Compounds containing –COOH are carboxylic acids."},
  {"id":307,"source":"CHM 102 Practice","topic":"Organic Chemistry – Nomenclature","question":"The compound H–C≡C–H is named:","options":{"A":"Ethene","B":"Ethane","C":"Ethyne (acetylene)","D":"Propyne"},"answer":"C","explanation":"H–C≡C–H: 2 carbons, one triple bond → eth + yne = ethyne. Common name: acetylene."},

  # More Gas Laws / Physical
  {"id":308,"source":"CHM 102 Practice","topic":"Gas Laws – STP","question":"At STP (0°C, 1 atm), the molar volume of an ideal gas is approximately:","options":{"A":"22.4 L/mol","B":"24.5 L/mol","C":"11.2 L/mol","D":"44.8 L/mol"},"answer":"A","explanation":"At STP (0°C and 1 atm), 1 mole of ideal gas occupies 22.4 L (molar volume)."},
  {"id":309,"source":"CHM 102 Practice","topic":"Gas Laws","question":"Which quantity is the same for equal volumes of any two ideal gases at the same temperature and pressure?","options":{"A":"Mass","B":"Density","C":"Number of molecules (Avogadro's law)","D":"Molar mass"},"answer":"C","explanation":"Avogadro's law: equal volumes of any ideal gases at the same T and P contain the same number of molecules."},
  {"id":310,"source":"CHM 102 Practice","topic":"Physical Chemistry","question":"The root mean square (rms) speed of gas molecules is given by:","options":{"A":"urms = √(3RT/M)","B":"urms = √(2RT/M)","C":"urms = √(8RT/πM)","D":"urms = √(RT/M)"},"answer":"A","explanation":"urms = √(3RT/M), where R = 8.314 J/mol·K, T in Kelvin, and M is molar mass in kg/mol."},

  # More acids & bases
  {"id":311,"source":"CHM 102 Practice","topic":"Acids & Bases – Buffer Capacity","question":"The Henderson–Hasselbalch equation for a buffer is:","options":{"A":"pH = pKa + log([A⁻]/[HA])","B":"pH = pKb − log([A⁻]/[HA])","C":"pH = 14 − pOH","D":"pH = −log[H⁺] + pKa"},"answer":"A","explanation":"Henderson–Hasselbalch: pH = pKa + log([conjugate base]/[weak acid]). At half-equivalence, [A⁻] = [HA] and pH = pKa."},
  {"id":312,"source":"CHM 102 Practice","topic":"Acids & Bases","question":"Which of the following aqueous solutions is ACIDIC?","options":{"A":"NaCl","B":"Na2CO3","C":"NH4Cl","D":"K2SO4"},"answer":"C","explanation":"NH4Cl → NH4⁺ + Cl⁻. NH4⁺ is the conjugate acid of a weak base (NH3), so it hydrolyses: NH4⁺ ⇌ NH3 + H⁺ → acidic."},
  {"id":313,"source":"CHM 102 Practice","topic":"Acids & Bases","question":"Which of the following is a Lewis acid?","options":{"A":"NH3","B":"H2O","C":"AlCl3","D":"OH⁻"},"answer":"C","explanation":"AlCl3 is electron-deficient (Al has only 6 electrons around it); it accepts an electron pair → Lewis acid."},
  {"id":314,"source":"CHM 102 Practice","topic":"Acids & Bases – Polyprotic Acids","question":"In the ionisation of H3PO4 (a triprotic acid), which Ka is the largest?","options":{"A":"Ka3","B":"Ka2","C":"Ka1","D":"All are equal"},"answer":"C","explanation":"Ka1 >> Ka2 >> Ka3 for polyprotic acids. It is always easier to remove the first proton from a neutral molecule than from an anion."},

  # More industrial/applied
  {"id":315,"source":"CHM 102 Practice","topic":"Applied Chemistry","question":"The optimum conditions for the Haber process (ammonia synthesis) represent a compromise because:","options":{"A":"High T increases yield but decreases rate","B":"High P increases yield and rate but is expensive and dangerous","C":"High T gives faster rate but lower equilibrium yield; high P gives better yield but high cost","D":"Low T gives maximum yield and maximum rate"},"answer":"C","explanation":"Exothermic reaction, so: low T → better yield but slow rate; high P → better yield; ~400–500°C and 200 atm is the industrial compromise."},
  {"id":316,"source":"CHM 102 Practice","topic":"Applied Chemistry – Corrosion","question":"Iron rusts (corrodes) when exposed to:","options":{"A":"Oxygen only","B":"Water only","C":"Both oxygen and water","D":"Carbon dioxide only"},"answer":"C","explanation":"Rusting requires both O2 and H2O. It is an electrochemical process: Fe is oxidised (anodic) while O2 is reduced (cathodic) in the presence of water."},
  {"id":317,"source":"CHM 102 Practice","topic":"Applied Chemistry","question":"Galvanising (zinc coating of iron) prevents corrosion because zinc:","options":{"A":"Is less reactive than iron","B":"Acts as a sacrificial anode (more reactive than iron)","C":"Seals the iron from air","D":"Reacts with water to form ZnO"},"answer":"B","explanation":"Zinc is more reactive than iron (lower reduction potential). Even if the zinc layer is scratched, Zn corrodes preferentially, protecting the iron."},

  # Kinetics extended
  {"id":318,"source":"CHM 102 Practice","topic":"Chemical Kinetics","question":"A reaction with rate = k is:","options":{"A":"First order","B":"Second order","C":"Zero order","D":"Third order"},"answer":"C","explanation":"Rate = k = k[A]⁰. This is zero order: the rate is independent of concentration."},
  {"id":319,"source":"CHM 102 Practice","topic":"Chemical Kinetics","question":"The rate-determining step (RDS) in a mechanism is:","options":{"A":"The fastest step","B":"The slowest step","C":"The step with the lowest activation energy","D":"The last step in the mechanism"},"answer":"B","explanation":"The RDS (slowest step) controls the overall reaction rate; it has the highest activation energy in the mechanism."},
  {"id":320,"source":"CHM 102 Practice","topic":"Chemical Kinetics","question":"Increasing the surface area of a solid reactant increases the reaction rate because:","options":{"A":"More solvent is available","B":"More reactant particles are exposed and available for collisions","C":"The activation energy decreases","D":"Temperature increases"},"answer":"B","explanation":"Greater surface area means more reactant surface is exposed to the other reactant, increasing the frequency of effective collisions."},

  # Coordination chemistry
  {"id":321,"source":"CHM 102 Practice","topic":"Coordination Chemistry","question":"In the complex [Cu(NH3)4]²⁺, the ligand NH3 acts as:","options":{"A":"Lewis acid","B":"Lewis base (electron pair donor)","C":"Bronsted acid","D":"Oxidising agent"},"answer":"B","explanation":"NH3 has a lone pair on N which it donates to the Cu²⁺ Lewis acid → NH3 is the Lewis base (ligand)."},
  {"id":322,"source":"CHM 102 Practice","topic":"Coordination Chemistry","question":"The colour of transition metal complexes arises from:","options":{"A":"Nuclear radiation","B":"d–d electronic transitions","C":"s–p transitions","D":"Ionic bonding"},"answer":"B","explanation":"Ligands split d orbitals into groups; electrons absorb visible light and undergo d–d transitions. The complementary colour is observed."},
  {"id":323,"source":"CHM 102 Practice","topic":"Coordination Chemistry","question":"EDTA is an example of a:","options":{"A":"Monodentate ligand","B":"Bidentate ligand","C":"Hexadentate ligand","D":"Tridentate ligand"},"answer":"C","explanation":"EDTA (ethylenediaminetetraacetate) has 6 donor atoms (2 N and 4 O) and is a hexadentate (6-toothed) chelating ligand."},

  # Organic reactions – more
  {"id":324,"source":"CHM 102 Practice","topic":"Organic Chemistry – Organic Halides","question":"The reaction of tert-butyl bromide with NaOH(aq) predominantly gives:","options":{"A":"tert-butyl alcohol via SN2","B":"tert-butyl alcohol via SN1","C":"2-methylpropene via E2","D":"2-methylpropene via E1 and tert-butyl alcohol via SN1"},"answer":"D","explanation":"Tertiary alkyl halides cannot undergo SN2. In polar protic solvent with weak nucleophile: SN1 (giving alcohol) and E1 (giving alkene) compete."},
  {"id":325,"source":"CHM 102 Practice","topic":"Organic Chemistry","question":"The Diels-Alder reaction is a [4+2] cycloaddition between:","options":{"A":"Two alkenes","B":"A diene and a dienophile (alkene)","C":"A diene and an alkyne only","D":"Two alkynes"},"answer":"B","explanation":"Diels-Alder: conjugated diene + dienophile → cyclohexene derivative (6-membered ring). It is concerted, stereospecific (syn addition)."},
  {"id":326,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"Gabriel synthesis is used to prepare:","options":{"A":"Secondary amines","B":"Primary amines (uncontaminated by secondary/tertiary amines)","C":"Amides","D":"Nitriles"},"answer":"B","explanation":"Gabriel synthesis: phthalimide → N-alkylphthalimide → primary amine (hydrazine hydrolysis). It avoids over-alkylation, giving pure 1° amines."},

  # More Analytical
  {"id":327,"source":"CHM 102 Practice","topic":"Analytical Chemistry","question":"A primary standard is a substance that:","options":{"A":"Is coloured","B":"Is of known, high purity, stable, and has a high molar mass for accurate weighing","C":"Must be dissolved in water only","D":"Changes colour in acid"},"answer":"B","explanation":"A primary standard must be: high purity, stable in air, known formula, high molar mass (to minimise weighing errors), readily soluble."},
  {"id":328,"source":"CHM 102 Practice","topic":"Analytical Chemistry","question":"Back titration is used when:","options":{"A":"The analyte is a liquid","B":"The analyte reacts too slowly or is insoluble","C":"The sample is very coloured","D":"The indicator is not available"},"answer":"B","explanation":"Back titration: add excess standard reagent to the analyte, then titrate the unreacted excess. Used for slow reactions or insoluble analytes."},

  # More nuclear
  {"id":329,"source":"CHM 102 Practice","topic":"Nuclear Chemistry","question":"Positron emission (β⁺ decay) results in:","options":{"A":"Mass number increasing by 1","B":"Atomic number increasing by 1","C":"Atomic number decreasing by 1","D":"Mass number decreasing by 4"},"answer":"C","explanation":"β⁺ decay: proton → neutron + positron (e⁺) + neutrino. Z decreases by 1; A stays the same."},
  {"id":330,"source":"CHM 102 Practice","topic":"Nuclear Chemistry","question":"Gamma rays are best described as:","options":{"A":"High-energy electrons","B":"Helium-4 nuclei","C":"High-energy electromagnetic radiation","D":"Neutrons"},"answer":"C","explanation":"Gamma (γ) rays are high-energy photons (electromagnetic radiation) with no mass or charge, emitted from excited nuclei."},
  {"id":331,"source":"CHM 102 Practice","topic":"Nuclear Chemistry","question":"In nuclear fission of U-235, the critical mass refers to:","options":{"A":"The temperature required for fission","B":"The minimum mass of fissile material needed for a self-sustaining chain reaction","C":"The total energy released","D":"The mass lost per fission event"},"answer":"B","explanation":"Critical mass: the minimum amount of fissile material at which enough neutrons are captured to sustain a chain reaction."},

  # Physical/Quantum
  {"id":332,"source":"CHM 102 Practice","topic":"Atomic Structure – Orbitals","question":"The shape of a 2p orbital is:","options":{"A":"Spherical","B":"Dumbbell-shaped","C":"Cloverleaf-shaped","D":"Ring-shaped"},"answer":"B","explanation":"p orbitals are dumbbell-shaped (two lobes); s orbitals are spherical; d orbitals are cloverleaf-shaped."},
  {"id":333,"source":"CHM 102 Practice","topic":"Atomic Structure – Quantum Numbers","question":"The Pauli exclusion principle states that:","options":{"A":"Electrons fill orbitals from lowest energy first","B":"No two electrons in an atom can have the same four quantum numbers","C":"Electrons in degenerate orbitals occupy separate orbitals before pairing","D":"Electrons exist in wave functions"},"answer":"B","explanation":"Pauli: no two electrons can have identical sets of quantum numbers (n, l, ml, ms). Hence each orbital holds at most 2 electrons with opposite spins."},
  {"id":334,"source":"CHM 102 Practice","topic":"Atomic Structure","question":"The energy of a photon of light is related to its frequency by:","options":{"A":"E = hc/λ² ","B":"E = hν","C":"E = mc","D":"E = h/λ"},"answer":"B","explanation":"Planck's equation: E = hν, where h = 6.626 × 10⁻³⁴ J·s and ν is frequency. Also written E = hc/λ."},

  # Organic – miscellaneous to reach 400
  {"id":335,"source":"CHM 102 Practice","topic":"Organic Chemistry","question":"Which of the following is NOT a characteristic of aromatic compounds?","options":{"A":"They are cyclic","B":"They contain (4n+2)π electrons (Hückel's rule)","C":"They undergo addition reactions preferentially","D":"They are planar"},"answer":"C","explanation":"Aromatic compounds preferentially undergo electrophilic SUBSTITUTION (not addition) to preserve aromaticity."},
  {"id":336,"source":"CHM 102 Practice","topic":"Organic Chemistry – Phenols","question":"Phenol reacts with bromine water WITHOUT a catalyst to give:","options":{"A":"Bromobenzene","B":"2,4,6-tribromophenol (white precipitate)","C":"4-bromophenol only","D":"No reaction"},"answer":"B","explanation":"The –OH group strongly activates the ring. Phenol reacts rapidly with Br2(aq) to give 2,4,6-tribromophenol (white precipitate) — no Lewis acid needed."},
  {"id":337,"source":"CHM 102 Practice","topic":"Organic Chemistry","question":"The reaction of an acid anhydride with water gives:","options":{"A":"Two molecules of the parent carboxylic acid","B":"An ester and a carboxylic acid","C":"An amide","D":"An alcohol"},"answer":"A","explanation":"(RCO)2O + H2O → 2 RCOOH. Hydrolysis of an anhydride gives two equivalents of the carboxylic acid."},
  {"id":338,"source":"CHM 102 Practice","topic":"Organic Chemistry","question":"Which compound forms a white precipitate with AgNO3 solution (silver nitrate test)?","options":{"A":"Chlorobenzene","B":"1-chlorobutane (alkyl chloride)","C":"Vinyl chloride","D":"Chloromethane (in water: hydrolyses slowly)"},"answer":"B","explanation":"Alkyl halides (especially primary and secondary) undergo SN2 with AgNO3 in ethanol to give AgX precipitate. Aryl halides and vinyl halides react too slowly."},
  {"id":339,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"Markovnikov's rule predicts the regioselectivity of addition of HX to an unsymmetrical alkene. The 'H' adds to the carbon bearing:","options":{"A":"Fewer hydrogen atoms","B":"More hydrogen atoms","C":"The halogen substituent","D":"The higher oxidation state"},"answer":"B","explanation":"Markovnikov: H adds to the carbon that already has more H's (forming the more stable, more substituted carbocation intermediate)."},
  {"id":340,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"The reaction of ethene with HBr in the presence of peroxides (ROOR) gives 1-bromoethane. This is because:","options":{"A":"The reaction follows Markovnikov's rule","B":"The reaction proceeds by a free-radical mechanism (anti-Markovnikov)","C":"HBr adds in a concerted mechanism","D":"Peroxides are Lewis acids"},"answer":"B","explanation":"Peroxides initiate free-radical chain reaction (Br• adds first to the less substituted carbon), giving anti-Markovnikov product."},

  # More kinetics/equilibrium
  {"id":341,"source":"CHM 102 Practice","topic":"Chemical Kinetics","question":"The collision theory of reaction rates states that a reaction occurs when:","options":{"A":"Any two molecules collide","B":"Molecules collide with sufficient energy and correct orientation","C":"Molecules are heated above 100°C","D":"The catalyst is added"},"answer":"B","explanation":"Effective collisions require: (1) sufficient kinetic energy (≥ Ea) and (2) correct relative orientation of reactants."},
  {"id":342,"source":"CHM 102 Practice","topic":"Chemical Equilibrium – Le Chatelier","question":"Adding an inert (non-reacting) gas at constant volume to an equilibrium system:","options":{"A":"Shifts equilibrium to the right","B":"Shifts equilibrium to the left","C":"Has no effect on the position of equilibrium","D":"Increases Kc"},"answer":"C","explanation":"Adding an inert gas at constant volume does not change partial pressures of reactants/products, so Kp and equilibrium position are unaffected."},
  {"id":343,"source":"CHM 102 Practice","topic":"Chemical Equilibrium","question":"A catalyst affects a chemical equilibrium by:","options":{"A":"Increasing the equilibrium constant","B":"Shifting the equilibrium to the right","C":"Increasing the rates of both forward and reverse reactions equally","D":"Increasing the yield of product"},"answer":"C","explanation":"A catalyst lowers activation energy equally for both directions. It speeds up reaching equilibrium without changing K or the equilibrium position."},

  # Nuclear / Radio
  {"id":344,"source":"CHM 102 Practice","topic":"Nuclear Chemistry","question":"Carbon-14 dating is based on the principle that:","options":{"A":"All living organisms contain the same amount of C-14 at death, which then decays at a known rate","B":"C-14 is produced only in rocks","C":"C-14 is stable","D":"The ratio of C-12 to C-13 changes with time"},"answer":"A","explanation":"Living organisms maintain C-14/C-12 ratio by exchange with atmosphere. At death, C-14 decays (t½ = 5730 yr), allowing age determination."},
  {"id":345,"source":"CHM 102 Practice","topic":"Nuclear Chemistry","question":"Nuclear binding energy per nucleon is greatest for:","options":{"A":"Hydrogen","B":"Iron-56","C":"Uranium-238","D":"Helium-4"},"answer":"B","explanation":"Fe-56 has the highest binding energy per nucleon (~8.8 MeV/nucleon). Elements lighter or heavier than Fe can release energy by fusion or fission respectively."},

  # Organic – miscellaneous
  {"id":346,"source":"CHM 102 Practice","topic":"Organic Chemistry","question":"Which of the following is used to distinguish between a primary, secondary, and tertiary alcohol?","options":{"A":"Fehling's test","B":"Tollens' test","C":"Lucas test (ZnCl2/HCl)","D":"Iodoform test"},"answer":"C","explanation":"Lucas test: tertiary alcohols react immediately (turbidity); secondary alcohols react in ~5 min; primary alcohols do not react (no turbidity at room temperature)."},
  {"id":347,"source":"CHM 102 Practice","topic":"Organic Chemistry – Aromatic","question":"Aniline (C6H5NH2) is less basic than cyclohexylamine because:","options":{"A":"Aniline has a higher molar mass","B":"The lone pair on N is delocalised into the benzene ring, reducing availability for protonation","C":"Aniline is insoluble in water","D":"The benzene ring withdraws electrons by induction only"},"answer":"B","explanation":"In aniline, the N lone pair is in resonance with the π system (reduced availability) → weaker base (pKb ≈ 9.4) compared to aliphatic amines (pKb ≈ 3.3)."},
  {"id":348,"source":"CHM 102 Practice","topic":"Organic Chemistry","question":"Saponification number of a fat/oil measures:","options":{"A":"The degree of unsaturation","B":"The milligrams of KOH needed to saponify 1 g of fat","C":"The free fatty acid content","D":"The peroxide content"},"answer":"B","explanation":"Saponification number: mg KOH required to hydrolyse (saponify) 1 g of fat. Higher value = lower average molar mass of constituent fatty acids."},
  {"id":349,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"The Claisen condensation is a reaction between:","options":{"A":"Two aldehydes in the presence of base","B":"An ester and a ketone with base","C":"Two esters (or an ester with itself) in the presence of a base to give a β-ketoester","D":"An acid and an alcohol"},"answer":"C","explanation":"Claisen: 2 RCOOR' → β-ketoester (RCOCH2COOR') + R'OH. An α-hydrogen of one ester is removed and attacks the carbonyl of another."},
  {"id":350,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"The aldol condensation results in:","options":{"A":"Formation of an ester","B":"Formation of a β-hydroxy carbonyl compound (aldol product)","C":"Reduction of an aldehyde","D":"Oxidation of a ketone"},"answer":"B","explanation":"Aldol: the α-carbon of one carbonyl compound attacks the carbonyl of another (or the same compound), giving a β-hydroxy aldehyde or ketone."},
  {"id":351,"source":"CHM 102 Practice","topic":"Organic Chemistry – NMR","question":"In ¹H NMR, the number of peaks (signals) indicates:","options":{"A":"The molecular weight","B":"The number of distinct hydrogen environments","C":"The number of carbon atoms","D":"The degree of unsaturation"},"answer":"B","explanation":"Each chemically distinct set of protons gives one ¹H NMR signal. The number of signals = number of chemically non-equivalent H environments."},
  {"id":352,"source":"CHM 102 Practice","topic":"Organic Chemistry – IR","question":"The carbonyl (C=O) stretch in IR spectroscopy appears approximately at:","options":{"A":"3300–3500 cm⁻¹","B":"1630–1820 cm⁻¹","C":"700–900 cm⁻¹","D":"2100–2260 cm⁻¹"},"answer":"B","explanation":"C=O stretching: 1630–1820 cm⁻¹. Acids ~1710 cm⁻¹, esters ~1735 cm⁻¹, aldehydes/ketones ~1715–1740 cm⁻¹."},

  # More Gas / Physical
  {"id":353,"source":"CHM 102 Practice","topic":"Gas Laws","question":"Effusion is the process by which a gas:","options":{"A":"Expands into a vacuum through a pinhole","B":"Dissolves in a liquid","C":"Reacts with another gas","D":"Liquefies under pressure"},"answer":"A","explanation":"Effusion: escape of a gas through a tiny hole into a vacuum. Graham's law: rate ∝ 1/√M."},
  {"id":354,"source":"CHM 102 Practice","topic":"Gas Laws","question":"Diffusion of gases refers to:","options":{"A":"Movement of gas through a tiny pinhole into vacuum","B":"Mixing of gas molecules due to random molecular motion","C":"Condensation of a gas","D":"Absorption of a gas by a solid"},"answer":"B","explanation":"Diffusion: spontaneous mixing of two or more gases due to random molecular motion. Effusion is through a pinhole; diffusion is through space."},

  # More inorganic bonding
  {"id":355,"source":"CHM 102 Practice","topic":"Chemical Bonding","question":"The percentage ionic character of a bond increases with:","options":{"A":"Decreasing electronegativity difference between atoms","B":"Increasing electronegativity difference between atoms","C":"Increasing bond length","D":"Decreasing bond energy"},"answer":"B","explanation":"Greater electronegativity difference → more unequal sharing of electrons → greater ionic character. 100% ionic character = infinite EN difference (theoretical)."},
  {"id":356,"source":"CHM 102 Practice","topic":"Chemical Bonding – Fajans' Rules","question":"According to Fajans' rules, covalent character in an ionic compound increases when the cation has:","options":{"A":"Small charge and large size","B":"Large charge and small size (high polarising power)","C":"Large charge and large size","D":"Small charge and small size"},"answer":"B","explanation":"Fajans' rules: small, highly charged cations (high polarising power) distort the anion's electron cloud, increasing covalent character."},
  {"id":357,"source":"CHM 102 Practice","topic":"Chemical Bonding","question":"Which bond is the LONGEST?","options":{"A":"C–C single bond","B":"C=C double bond","C":"C≡C triple bond","D":"C–H bond"},"answer":"A","explanation":"Bond length increases with decreasing bond order (more electrons shared = shorter, stronger bond). C–C (154 pm) > C=C (134 pm) > C≡C (120 pm)."},
  {"id":358,"source":"CHM 102 Practice","topic":"Chemical Bonding","question":"The bond angle in CH4 (methane) is:","options":{"A":"90°","B":"104.5°","C":"109.5°","D":"120°"},"answer":"C","explanation":"CH4: 4 equivalent bond pairs, no lone pairs (sp3). Tetrahedral geometry → bond angle = 109.5°."},

  # Environmental chemistry
  {"id":359,"source":"CHM 102 Practice","topic":"Environmental Chemistry","question":"Ozone (O3) in the STRATOSPHERE is important because it:","options":{"A":"Causes global warming","B":"Absorbs harmful UV-B and UV-C radiation from the sun","C":"Produces acid rain","D":"Provides oxygen for breathing"},"answer":"B","explanation":"Stratospheric ozone absorbs biologically harmful UV-B (280–315 nm) and UV-C (<280 nm), protecting life on Earth."},
  {"id":360,"source":"CHM 102 Practice","topic":"Environmental Chemistry","question":"CFCs (chlorofluorocarbons) destroy stratospheric ozone because:","options":{"A":"They react with N2 to form NO, which destroys O3","B":"UV breaks them down to release Cl atoms, which catalytically destroy O3","C":"They absorb UV and heat the stratosphere","D":"They react with O2 to form O3"},"answer":"B","explanation":"UV photolysis of CFCs releases Cl•, which reacts: Cl• + O3 → ClO• + O2, then ClO• + O• → Cl• + O2. Each Cl atom can destroy ~100,000 O3 molecules."},

  # More reactions
  {"id":361,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"The Sandmeyer reaction is used to convert a diazonium salt to:","options":{"A":"An amine","B":"A phenol, aryl halide, or nitrile","C":"An ester","D":"An amide"},"answer":"B","explanation":"Sandmeyer: ArN2⁺ + CuX (or CuCN) → ArX (or ArCN). Also: ArN2⁺ + H3PO2 → ArH (reduction)."},
  {"id":362,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"The Cannizzaro reaction occurs when:","options":{"A":"Two molecules of an aldehyde with no α-H undergo disproportionation","B":"An aldehyde is reduced by LiAlH4","C":"Two ketones undergo condensation","D":"An aldehyde is oxidised by Tollens' reagent"},"answer":"A","explanation":"Cannizzaro reaction: 2RCHO (no α-H) → RCOO⁻ + RCH2OH. One molecule is oxidised; the other is reduced (disproportionation)."},
  {"id":363,"source":"CHM 102 Practice","topic":"Organic Chemistry","question":"The Wolff–Kishner reduction converts a ketone (or aldehyde) to:","options":{"A":"An alcohol","B":"A carboxylic acid","C":"A methylene group (alkane)","D":"An amine"},"answer":"C","explanation":"Wolff–Kishner: C=O + N2H4 → hydrazone → C=N-NH2 → (KOH/Δ) → CH2 (alkane). Clemmensen reduction (Zn-Hg/HCl) does the same under acidic conditions."},

  # More equilibrium
  {"id":364,"source":"CHM 102 Practice","topic":"Chemical Equilibrium","question":"The reaction quotient (Q) is used to:","options":{"A":"Calculate activation energy","B":"Determine the direction a reaction will proceed to reach equilibrium","C":"Calculate equilibrium constant","D":"Measure reaction rate"},"answer":"B","explanation":"Q calculated from current concentrations: if Q < K → forward; if Q > K → reverse; if Q = K → at equilibrium."},
  {"id":365,"source":"CHM 102 Practice","topic":"Chemical Equilibrium","question":"The equilibrium constant K is affected by:","options":{"A":"Changes in concentration","B":"Changes in pressure","C":"Addition of a catalyst","D":"Changes in temperature"},"answer":"D","explanation":"K is temperature-dependent only (van't Hoff equation: d lnK/dT = ΔH°/RT²). Concentration, pressure, and catalysts do not change K."},

  # More atomic/quantum
  {"id":366,"source":"CHM 102 Practice","topic":"Atomic Structure","question":"Heisenberg's uncertainty principle states that it is impossible to simultaneously determine with precision:","options":{"A":"The charge and mass of an electron","B":"The position and momentum of a particle","C":"The energy and charge of a photon","D":"The wavelength and frequency of light"},"answer":"B","explanation":"Δx × Δp ≥ h/4π. The more precisely the position is known, the less precisely the momentum is known, and vice versa."},
  {"id":367,"source":"CHM 102 Practice","topic":"Atomic Structure","question":"The concept of electron spin was introduced to explain:","options":{"A":"Atomic emission spectra","B":"The Pauli exclusion principle","C":"Fine structure in atomic spectra (splitting in a magnetic field)","D":"Both B and C"},"answer":"D","explanation":"Electron spin (ms = ±½) explains: (1) why two electrons in an orbital must have opposite spins (Pauli), and (2) fine splitting of spectral lines (Zeeman effect)."},

  # Applied organic
  {"id":368,"source":"CHM 102 Practice","topic":"Organic Chemistry – Applied","question":"Aspirin (acetylsalicylic acid) is prepared by the acetylation of salicylic acid with:","options":{"A":"Acetic acid alone","B":"Acetic anhydride","C":"Ethanol","D":"Acetyl chloride with AlCl3"},"answer":"B","explanation":"Salicylic acid + acetic anhydride → aspirin + acetic acid. Acetic anhydride is preferred over acetic acid for kinetic reasons."},
  {"id":369,"source":"CHM 102 Practice","topic":"Organic Chemistry – Applied","question":"DDT is an example of a:","options":{"A":"Natural pesticide","B":"Persistent organochlorine pesticide","C":"Biodegradable herbicide","D":"Fungicide"},"answer":"B","explanation":"DDT (dichlorodiphenyltrichloroethane) is a synthetic organochlorine insecticide; it is very persistent in the environment and bioaccumulates in food chains."},
  {"id":370,"source":"CHM 102 Practice","topic":"Organic Chemistry – Dyes","question":"Azo dyes are characterised by the presence of the group:","options":{"A":"–OH","B":"–N=N– (azo group)","C":"–NH2","D":"–COOH"},"answer":"B","explanation":"Azo dyes contain the –N=N– (azo) linkage. They are made by coupling a diazonium salt with an aromatic amine or phenol."},

  # Solution / Colloids
  {"id":371,"source":"CHM 102 Practice","topic":"Colloids","question":"The Tyndall effect is used to distinguish:","options":{"A":"Acids from bases","B":"True solutions from colloids","C":"Ionic from covalent compounds","D":"Metals from non-metals"},"answer":"B","explanation":"Colloids scatter light (Tyndall effect — the beam is visible); true solutions do not scatter light significantly because particle size is too small."},
  {"id":372,"source":"CHM 102 Practice","topic":"Colloids","question":"Which of the following is an example of a colloidal sol?","options":{"A":"Salt water","B":"Milk","C":"Sugar solution","D":"Air (normal atmosphere)"},"answer":"B","explanation":"Milk is an oil-in-water emulsion (fat droplets dispersed in water); it is a colloidal system. Salt and sugar solutions are true solutions."},

  # Electrochemistry / corrosion
  {"id":373,"source":"CHM 102 Practice","topic":"Electrochemistry – Corrosion","question":"The electrochemical theory of rusting involves iron acting as:","options":{"A":"Cathode in an electrochemical cell","B":"Anode in an electrochemical cell (oxidised)","C":"Inert electrode","D":"Reducing agent toward oxygen"},"answer":"B","explanation":"Rust: Fe is oxidised (Fe → Fe²⁺ + 2e⁻) at the anode; O2 is reduced at the cathode (O2 + 2H2O + 4e⁻ → 4OH⁻). Water acts as electrolyte."},
  {"id":374,"source":"CHM 102 Practice","topic":"Electrochemistry","question":"The standard hydrogen electrode (SHE) conditions are:","options":{"A":"H2 at 1 atm, H⁺ at 1 M, 25°C","B":"H2 at 2 atm, H⁺ at 2 M, 0°C","C":"H2 at 0.5 atm, H⁺ at 0.1 M, 25°C","D":"H2 at 1 atm, pH 7, 25°C"},"answer":"A","explanation":"SHE: Pt electrode, H2 gas at 1 atm, [H⁺] = 1 mol/L, 25°C. E° = 0.00 V by definition."},

  # More periodic / inorganic
  {"id":375,"source":"CHM 102 Practice","topic":"Inorganic Chemistry – Period 3","question":"Which Period 3 oxide reacts with water to form a strong acid?","options":{"A":"Na2O","B":"MgO","C":"Al2O3","D":"P4O10"},"answer":"D","explanation":"P4O10 + 6H2O → 4H3PO4 (phosphoric acid). Na2O → NaOH (strong base); MgO → Mg(OH)2 (weak base); Al2O3 is amphoteric but insoluble."},
  {"id":376,"source":"CHM 102 Practice","topic":"Inorganic Chemistry","question":"The Claus process is used to recover __________ from hydrogen sulphide.","options":{"A":"Sulphur","B":"Sulphur dioxide","C":"Sulphuric acid","D":"Hydrogen"},"answer":"A","explanation":"Claus process: 2H2S + SO2 → 3S + 2H2O (plus initial combustion step). Elemental sulphur is recovered from H2S in oil refining."},
  {"id":377,"source":"CHM 102 Practice","topic":"Inorganic Chemistry – Group 17","question":"The bleaching power of halogens decreases in the order:","options":{"A":"I2 > Br2 > Cl2 > F2","B":"Cl2 > Br2 > F2 > I2","C":"F2 > Cl2 > Br2 > I2","D":"Cl2 > I2 > Br2 > F2"},"answer":"C","explanation":"Bleaching power ∝ oxidising power. F2 > Cl2 > Br2 > I2. However, F2 is too reactive and dangerous for domestic use; Cl2 is the practical bleaching halogen."},

  # More Stoichiometry / Moles
  {"id":378,"source":"CHM 102 Practice","topic":"Stoichiometry","question":"How many molecules are in 1 mole of any substance? (Avogadro's number)","options":{"A":"6.022 × 10²³","B":"3.011 × 10²³","C":"1.204 × 10²⁴","D":"6.022 × 10²⁴"},"answer":"A","explanation":"Avogadro's constant: NA = 6.022 × 10²³ mol⁻¹. One mole of any substance contains NA entities (atoms, molecules, ions, etc.)."},
  {"id":379,"source":"CHM 102 Practice","topic":"Stoichiometry","question":"How many moles of atoms are in 36 g of water (M = 18 g/mol)?","options":{"A":"1 mol","B":"2 mol","C":"3 mol (2 mol H + 1 mol O per molecule × 2 mol H2O)","D":"6 mol"},"answer":"D","explanation":"mol H2O = 36/18 = 2 mol. Each H2O has 3 atoms: 2H + 1O. Total atoms = 2 × 3 = 6 mol atoms."},
  {"id":380,"source":"CHM 102 Practice","topic":"Stoichiometry","question":"The percentage yield of a reaction is calculated as:","options":{"A":"(actual yield / theoretical yield) × 100%","B":"(theoretical yield / actual yield) × 100%","C":"(actual yield × 100) / molar mass","D":"(theoretical yield − actual yield) × 100%"},"answer":"A","explanation":"% yield = (actual yield obtained / theoretical maximum yield) × 100%."},

  # More thermodynamics / spontaneity
  {"id":381,"source":"CHM 102 Practice","topic":"Thermodynamics","question":"When ΔH > 0 and ΔS < 0, the reaction is:","options":{"A":"Always spontaneous","B":"Spontaneous at high temperature","C":"Never spontaneous (non-spontaneous at all temperatures)","D":"Spontaneous at low temperature"},"answer":"C","explanation":"ΔG = ΔH − TΔS. If ΔH > 0 and ΔS < 0, then ΔG = (+) − T(−) = (+) + T(+) > 0 always → never spontaneous."},
  {"id":382,"source":"CHM 102 Practice","topic":"Thermodynamics","question":"An endothermic dissolution process is SPONTANEOUS because:","options":{"A":"ΔH drives spontaneity","B":"The increase in entropy (ΔS > 0) outweighs the positive ΔH, making ΔG < 0","C":"The process absorbs heat from surroundings","D":"The solvent cools down"},"answer":"B","explanation":"ΔG = ΔH − TΔS. For endothermic dissolution, ΔH > 0 but ΔS >> 0 (mixing increases disorder), so at sufficient T, TΔS > ΔH → ΔG < 0."},

  # more bonds / IMF
  {"id":383,"source":"CHM 102 Practice","topic":"Intermolecular Forces","question":"Which substance has the HIGHEST boiling point due to the STRONGEST intermolecular forces?","options":{"A":"CH4","B":"NaCl","C":"H2O","D":"CO2"},"answer":"B","explanation":"NaCl is an ionic solid with strong electrostatic interactions (lattice energy ~790 kJ/mol); its melting point is 801°C — much higher than the molecular substances listed."},
  {"id":384,"source":"CHM 102 Practice","topic":"Intermolecular Forces","question":"Which of the following has ONLY London dispersion forces?","options":{"A":"HF","B":"H2O","C":"NH3","D":"CH4"},"answer":"D","explanation":"CH4 is non-polar and has no lone pairs for hydrogen bonding → only London (dispersion) forces exist between molecules."},
  {"id":385,"source":"CHM 102 Practice","topic":"Intermolecular Forces","question":"The unusually high boiling point of water (100°C) compared to H2S (−60°C) is due to:","options":{"A":"Higher molar mass of water","B":"Extensive hydrogen bonding in liquid water","C":"Greater London dispersion forces in water","D":"Ionic character of water"},"answer":"B","explanation":"Water forms extensive H-bonds (O–H···O) in the liquid phase; H2S is too large for H-bonding. This explains water's anomalously high boiling point."},
  {"id":386,"source":"CHM 102 Practice","topic":"Intermolecular Forces","question":"Dipole–dipole forces act between:","options":{"A":"Non-polar molecules","B":"Polar molecules with permanent dipoles","C":"Ions","D":"Atoms of noble gases"},"answer":"B","explanation":"Dipole–dipole interactions occur between molecules that have permanent dipole moments (polar molecules). They are stronger than London forces for similar molar masses."},

  # More organic reactions
  {"id":387,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"Benzoic acid can be obtained by the oxidation of toluene using:","options":{"A":"Dilute H2SO4","B":"KMnO4 or K2Cr2O7 / H⁺","C":"Conc. HNO3","D":"H2 / Pd"},"answer":"B","explanation":"Oxidation of the methyl group on toluene (C6H5CH3) with hot acidified KMnO4 gives benzoic acid (C6H5COOH)."},
  {"id":388,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"A Grignard reagent reacts with CO2 (dry ice) to give, after aqueous workup:","options":{"A":"An alcohol","B":"A ketone","C":"A carboxylic acid","D":"An ester"},"answer":"C","explanation":"RMgX + CO2 → RCOOMgX → (H3O⁺) → RCOOH (carboxylic acid). This is a key synthesis of carboxylic acids."},
  {"id":389,"source":"CHM 102 Practice","topic":"Organic Chemistry","question":"The reaction of a carboxylic acid with excess LiAlH4 gives:","options":{"A":"An aldehyde","B":"A primary alcohol","C":"A ketone","D":"An ester"},"answer":"B","explanation":"LiAlH4 reduces carboxylic acids all the way to primary alcohols: RCOOH → RCH2OH."},
  {"id":390,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"Alkenes react with hot concentrated H2SO4 to give, after steam distillation:","options":{"A":"An aldehyde","B":"An ether","C":"A Markovnikov alcohol","D":"A sulphonic acid"},"answer":"C","explanation":"H2SO4 adds across the double bond (Markovnikov) to give an alkyl sulphate, which hydrolyses in steam to give the Markovnikov alcohol."},

  # Final batch to reach 400
  {"id":391,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"The Baeyer test (cold dilute KMnO4, purple) is used to test for:","options":{"A":"Primary alcohols","B":"Unsaturation (double or triple bonds)","C":"Aldehydes","D":"Aromatic compounds"},"answer":"B","explanation":"Cold dilute KMnO4 decolourises (turns from purple to brown/colourless) in the presence of alkenes, alkynes, and aldehydes (unsaturated bonds)."},
  {"id":392,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"Pyrolysis (thermal cracking) of alkanes primarily gives:","options":{"A":"Alkenes and H2","B":"Alcohols and CO2","C":"Carboxylic acids","D":"Noble gases"},"answer":"A","explanation":"High-temperature (>700°C) thermal cracking of alkanes gives alkenes and H2: CnH2n+2 → CmH2m + C(n-m)H2(n-m)+2 + H2."},
  {"id":393,"source":"CHM 102 Practice","topic":"Organic Chemistry","question":"The degree of unsaturation (DoU) formula for a compound CₙHₘN_pO_qX_r is:","options":{"A":"DoU = (2n + 2 − m + p − r) / 2","B":"DoU = (2n + 2 + m) / 2","C":"DoU = n − m/2","D":"DoU = 2n − m"},"answer":"A","explanation":"DoU = (2C + 2 + N − H − X) / 2, where O and S do not appear. Each ring or double bond = 1 DoU; triple bond = 2 DoU."},
  {"id":394,"source":"CHM 102 Practice","topic":"Organic Chemistry – Reactions","question":"Transesterification is:","options":{"A":"Hydrolysis of an ester to give an acid and an alcohol","B":"Exchange of the alkoxy group of an ester with another alcohol","C":"Formation of an ester from an acid chloride","D":"Reduction of an ester to a primary alcohol"},"answer":"B","explanation":"Transesterification: RCOOR' + R''OH ⇌ RCOOR'' + R'OH. The alkoxy group is exchanged; used in biodiesel production."},
  {"id":395,"source":"CHM 102 Practice","topic":"Organic Chemistry","question":"Which of the following is the CORRECT order of acidity for carboxylic acid derivatives?","options":{"A":"Acid chloride > anhydride > ester > amide","B":"Ester > amide > anhydride > acid chloride","C":"Amide > ester > anhydride > acid chloride","D":"Acid chloride > ester > amide > anhydride"},"answer":"A","explanation":"Reactivity toward nucleophilic acyl substitution (and hence acidity of the conjugate leaving group): acid chloride > anhydride > ester > amide."},
  {"id":396,"source":"CHM 102 Practice","topic":"Organic Chemistry – Amino Acids","question":"The isoelectric point (pI) of an amino acid is the pH at which:","options":{"A":"The amino acid is positively charged","B":"The amino acid is negatively charged","C":"The amino acid exists as a zwitterion (net charge = 0)","D":"The amino acid is fully protonated"},"answer":"C","explanation":"At the isoelectric point, the amino acid has equal numbers of positive and negative charges (zwitterion form, net charge = 0)."},
  {"id":397,"source":"CHM 102 Practice","topic":"Organic Chemistry","question":"Which type of bond links nucleotides in DNA?","options":{"A":"Peptide bonds","B":"Hydrogen bonds","C":"Phosphodiester bonds","D":"Glycosidic bonds"},"answer":"C","explanation":"The sugar-phosphate backbone of DNA is linked by phosphodiester bonds (3'→5') between adjacent nucleotides."},
  {"id":398,"source":"CHM 102 Practice","topic":"Organic Chemistry","question":"The major structural difference between DNA and RNA is:","options":{"A":"DNA contains uracil; RNA contains thymine","B":"DNA contains deoxyribose sugar; RNA contains ribose sugar","C":"DNA is single-stranded; RNA is double-stranded","D":"DNA contains adenine; RNA does not"},"answer":"B","explanation":"DNA: 2'-deoxyribose (no 2'-OH) and thymine (T). RNA: ribose (with 2'-OH) and uracil (U) instead of thymine."},
  {"id":399,"source":"CHM 102 Practice","topic":"Inorganic Chemistry","question":"Which of the following statements about lanthanide contraction is TRUE?","options":{"A":"Atomic radii of lanthanides increase significantly along the series","B":"Poor shielding by 4f electrons causes atomic radii to decrease slightly across the lanthanide series","C":"Lanthanides have the same radius as transition metals","D":"Lanthanide contraction affects Group 1 elements"},"answer":"B","explanation":"The 4f orbitals shield nuclear charge poorly; as Z increases across the lanthanides, nuclear attraction slightly contracts the atom → lanthanide contraction."},
  {"id":400,"source":"CHM 102 Practice","topic":"Inorganic Chemistry – d-block","question":"Ferrocene, [Fe(C5H5)2], is an example of a:","options":{"A":"Ionic complex","B":"Sandwich compound (organometallic)","C":"Chelate complex","D":"Werner-type complex"},"answer":"B","explanation":"Ferrocene is an organometallic sandwich compound: two cyclopentadienyl (Cp) rings sandwich the Fe²⁺ ion from above and below via η⁵ coordination."},
]

